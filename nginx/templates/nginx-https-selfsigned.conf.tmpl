# Athena Nginx Configuration - HTTPS Mode (Self-Signed Certificates)
# Generated from template by setup wizard

# Rate limiting zone
limit_req_zone $binary_remote_addr zone=api_limit:10m rate=10r/s;

# Gzip compression
gzip on;
gzip_vary on;
gzip_min_length 1024;
gzip_types text/plain text/css application/json application/javascript text/xml application/xml video/mp2t application/vnd.apple.mpegurl;

# Upstream - Athena Go application
upstream athena_app {
    server {{.UpstreamAddr}};
    keepalive 32;
}

# HTTP redirect to HTTPS
server {
    listen 80;
    server_name {{.Domain}};

    # Nginx health check (also available on HTTP)
    location /nginx-health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # Redirect all other HTTP to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name {{.Domain}};

    # SSL certificates (self-signed)
    ssl_certificate /etc/nginx/ssl/self-signed.crt;
    ssl_certificate_key /etc/nginx/ssl/self-signed.key;
    ssl_dhparam /etc/nginx/ssl/dhparam.pem;

    # SSL protocols and ciphers (modern configuration)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # SSL session cache
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # OCSP stapling (not applicable for self-signed, but kept for consistency)
    ssl_stapling off;
    ssl_stapling_verify off;

    # Client upload limits
    client_max_body_size 0;

    # Security headers
    include /etc/nginx/conf.d/common-security.conf;

    # HSTS (HTTP Strict Transport Security) - 1 year
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Nginx health check endpoint
    location /nginx-health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # Static files - storage volume
    location /storage/ {
        alias /app/storage/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Static files - processed volume (thumbnails, HLS segments)
    location /processed/ {
        alias /app/processed/;

        # Different caching for different file types
        location ~* \.(m3u8)$ {
            expires 1h;
            add_header Cache-Control "public";
        }
        location ~* \.(ts)$ {
            expires 1h;
            add_header Cache-Control "public";
        }
        location ~* \.(jpg|jpeg|png|webp)$ {
            expires 7d;
            add_header Cache-Control "public, immutable";
        }

        access_log off;
    }

    # WebSocket endpoint for live chat
    location /ws/ {
        proxy_pass http://athena_app;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        include /etc/nginx/conf.d/common-proxy.conf;
    }

    # API endpoints with rate limiting
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;
        proxy_pass http://athena_app;
        include /etc/nginx/conf.d/common-proxy.conf;
    }

    # All other requests proxied to app
    location / {
        proxy_pass http://athena_app;
        include /etc/nginx/conf.d/common-proxy.conf;
    }
}
