# Athena - PeerTube Backend Configuration
# Copy this file to .env and update with your production values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgres://athena_user:athena_password@localhost:5432/athena?sslmode=disable

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# =============================================================================
# IPFS CONFIGURATION
# =============================================================================
IPFS_API=http://localhost:5001
IPFS_CLUSTER_API=http://localhost:9094

# =============================================================================
# IOTA CONFIGURATION (Optional)
# =============================================================================
ENABLE_IOTA=false
IOTA_NODE_URL=https://api.testnet.shimmer.network

# =============================================================================
# S3-COMPATIBLE STORAGE (Optional)
# =============================================================================
ENABLE_S3=false
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=athena-videos
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# =============================================================================
# UPLOAD CONFIGURATION
# =============================================================================
MAX_UPLOAD_SIZE=5368709120
CHUNK_SIZE=33554432
MAX_CONCURRENT_UPLOADS=10

# =============================================================================
# PROCESSING CONFIGURATION
# =============================================================================
MAX_PROCESSING_WORKERS=4
PROCESSING_TIMEOUT=3600

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-CSRF-Token,X-Requested-With,Idempotency-Key

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
HEALTH_CHECK_TIMEOUT=30
DB_PING_TIMEOUT=5
REDIS_PING_TIMEOUT=3
IPFS_PING_TIMEOUT=10

# =============================================================================
# VIDEO PROCESSING CONFIGURATION
# =============================================================================
VIDEO_QUALITIES=240p,360p,480p,720p,1080p,1440p,2160p,4320p
HLS_SEGMENT_DURATION=4
THUMBNAIL_COUNT=3

# =============================================================================
# HLS SIGNING CONFIGURATION
# =============================================================================
HLS_SIGNING_SECRET=your-hls-signing-secret
HLS_TOKEN_TTL=600

# =============================================================================
# STORAGE TIERS CONFIGURATION
# =============================================================================
HOT_STORAGE_LIMIT=100GB
WARM_STORAGE_LIMIT=1TB
COLD_STORAGE_ENABLED=true

# =============================================================================
# PINNING STRATEGY CONFIGURATION
# =============================================================================
PINNING_REPLICATION_FACTOR=3
PINNING_SCORE_THRESHOLD=0.3
PINNING_BACKUP_ENABLED=true

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_TIMEOUT=86400
REFRESH_TOKEN_TIMEOUT=604800

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_TIMEOUT=60
API_MAX_REQUEST_SIZE=10MB
API_PAGINATION_DEFAULT_LIMIT=20
API_PAGINATION_MAX_LIMIT=100

# =============================================================================
# VALIDATION CONFIGURATION
# =============================================================================
VALIDATION_STRICT_MODE=false
VALIDATION_ALLOWED_ALGORITHMS=sha256
VALIDATION_TEST_MODE=false
VALIDATION_ENABLE_INTEGRITY_JOBS=true
VALIDATION_LOG_EVENTS=true

# =============================================================================
# ENCODING SCHEDULER CONFIGURATION
# =============================================================================
ENABLE_ENCODING_SCHEDULER=true
ENCODING_SCHEDULER_INTERVAL_SECONDS=5
ENCODING_SCHEDULER_BURST=3

# =============================================================================
# FFMPEG CONFIGURATION
# =============================================================================
FFMPEG_PATH=ffmpeg
