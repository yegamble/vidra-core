# Server Configuration
PORT=8080

# Database Configuration
DATABASE_URL=postgres://vidra_user:vidra_password@localhost:5432/vidra?sslmode=disable

# Database Migrations (Goose)
# This project uses Goose for migrations: https://github.com/pressly/goose
# Run: make migrate-up (or: goose -dir migrations postgres "$DATABASE_URL" up)

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# IPFS Configuration
IPFS_API=http://localhost:5001
IPFS_CLUSTER_API=http://localhost:9094
REQUIRE_IPFS=true
# Local IPFS gateway URL (Kubo exposes gateway on port 8080 by default)
# Used to construct avatar retrieval URLs and proxy endpoint
# Docker: mapped to host port 9090 (docker-compose.yml), container-to-container uses http://ipfs:8080
IPFS_LOCAL_GATEWAY_URL=http://localhost:9090

# IPFS Streaming Configuration
# Enable IPFS streaming for HLS delivery (experimental)
ENABLE_IPFS_STREAMING=false
# Comma-separated list of IPFS gateway URLs
# IPFS_GATEWAY_URLS=https://ipfs.io,https://dweb.link,https://cloudflare-ipfs.com
# Timeout for IPFS streaming requests in seconds
# IPFS_STREAMING_TIMEOUT=30
# Prefer local filesystem over IPFS for streaming (faster)
# IPFS_STREAMING_PREFER_LOCAL=true
# Gateway health check interval in seconds
# IPFS_GATEWAY_HEALTH_CHECK_INTERVAL=60
# Max retries for failed IPFS streaming requests
# IPFS_STREAMING_MAX_RETRIES=3
# Fallback to local filesystem if IPFS fails
# IPFS_STREAMING_FALLBACK_TO_LOCAL=true
# Buffer size for IPFS streaming in bytes
# IPFS_STREAMING_BUFFER_SIZE=32768

# IOTA Configuration
# IOTA Rebased testnet JSON-RPC endpoint
IOTA_NODE_URL=https://api.testnet.iotaledger.net
# Encryption key for IOTA wallet private keys stored in DB (hex-encoded 32 bytes)
# Generate with: openssl rand -hex 32
# IOTA_WALLET_ENCRYPTION_KEY=

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg

# Setup Wizard
# Set to "true" after initial setup is complete; "false" forces setup mode
# SETUP_COMPLETED=

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Optional separate JWT secret for PeerTube API compatibility
# PEERTUBE_JWT_SECRET=

# Storage Configuration
# STORAGE_DIR=./storage

# Session/Token TTLs
# Session timeout in seconds (Redis session TTL); default 86400 (24h)
# SESSION_TIMEOUT=86400
# Refresh token timeout in seconds; default 604800 (7 days)
# REFRESH_TOKEN_TIMEOUT=604800

# Feature Flags
ENABLE_IOTA=false
ENABLE_IPFS_CLUSTER=true
ENABLE_S3=false

# S3-Compatible Storage (optional)
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

# Object Storage Advanced Configuration
# Upload ACL for public/unlisted videos (use "null" for Backblaze B2)
# S3_UPLOAD_ACL_PUBLIC=public-read
# Upload ACL for private/internal videos (use "null" for Backblaze B2)
# S3_UPLOAD_ACL_PRIVATE=private
# Proxy private S3 files through server instead of signed URL redirect
# S3_PROXIFY_PRIVATE_FILES=true
# Maximum upload part size (e.g., 100MB for Backblaze B2)
# S3_MAX_UPLOAD_PART=100MB
# Maximum retry attempts for S3 requests (recommended: 3-5 for Backblaze)
# S3_MAX_REQUEST_ATTEMPTS=3
# Use path-style S3 URLs (required for some providers like Backblaze)
# S3_PATH_STYLE=false
# Store live streams in object storage
# S3_STORE_LIVE_STREAMS=false

# Per-Category S3 Configuration (prefixes and CDN base URLs)
# Streaming playlists (HLS)
# S3_STREAMING_PLAYLISTS_PREFIX=streaming-playlists/
# S3_STREAMING_PLAYLISTS_BASE_URL=
# Web videos
# S3_WEB_VIDEOS_PREFIX=web-videos/
# S3_WEB_VIDEOS_BASE_URL=
# User exports
# S3_USER_EXPORTS_PREFIX=user-exports/
# S3_USER_EXPORTS_BASE_URL=
# Original video files
# S3_ORIGINAL_VIDEO_FILES_PREFIX=original-video-files/
# S3_ORIGINAL_VIDEO_FILES_BASE_URL=
# Video captions
# S3_CAPTIONS_PREFIX=captions/
# S3_CAPTIONS_BASE_URL=

# Content Security Policy (CSP)
# Enable CSP headers
# CSP_ENABLED=true
# Use report-only mode (logs violations without blocking)
# CSP_REPORT_ONLY=false
# CSP violation report endpoint
# CSP_REPORT_URI=

# Static Files Authentication
# Require authentication for private static files
# STATIC_FILES_PRIVATE_AUTH=true

# Upload Configuration
MAX_UPLOAD_SIZE=5368709120
CHUNK_SIZE=33554432
MAX_CONCURRENT_UPLOADS=10
# MAX_BATCH_UPLOAD_SIZE=10
# Max total video storage per user (bytes); default 50GB
# MAX_USER_VIDEO_QUOTA=53687091200

# Processing Configuration
MAX_PROCESSING_WORKERS=4
PROCESSING_TIMEOUT=3600

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Accept,Authorization,Content-Type,X-CSRF-Token,X-Requested-With,Idempotency-Key

# Logging Configuration
LOG_LEVEL=info                # debug | info | warn | error
LOG_FORMAT=json               # json (production) | text (development)

# Log File Output (PeerTube parity: log.rotation.*)
# LOG_DIR=                    # Directory for log files (empty = stderr only, no file logging)
# LOG_FILENAME=vidra.log      # Main log file name
# AUDIT_LOG_FILENAME=vidra-audit.log  # Audit log file name

# Log Rotation (enabled when LOG_DIR is set)
# LOG_ROTATION_ENABLED=true
# LOG_ROTATION_MAX_SIZE_MB=12   # Max size per log file in megabytes before rotation
# LOG_ROTATION_MAX_FILES=20     # Max number of rotated log files to retain
# LOG_ROTATION_MAX_AGE_DAYS=0   # Max days to retain rotated files (0 = disabled)

# Log Behavior Toggles (PeerTube parity: log.anonymize_ip, log.log_http_requests, etc.)
# LOG_ANONYMIZE_IP=false        # Anonymize client IPs in HTTP logs (also enabled by DNT: 1 header)
# LOG_HTTP_REQUESTS=true        # Log all HTTP requests (disable for high-throughput deployments)
# LOG_PING_REQUESTS=true        # Log /api/v1/ping and /health requests (disable to reduce noise)
# LOG_ACCEPT_CLIENT_LOG=true    # Accept client-side logs at POST /api/v1/server/logs/client

# HLS Signing (optional)
# HLS_SIGNING_SECRET=
# HLS_TOKEN_TTL=600

# Encoding scheduler (API-driven)
# Set to false to disable scheduler in API server and rely only on standalone encoder worker
ENABLE_ENCODING_SCHEDULER=true
# Poll interval in seconds and max jobs processed per tick
ENCODING_SCHEDULER_INTERVAL_SECONDS=5
ENCODING_SCHEDULER_BURST=3

# Image/Avatar Encoding
# Optional WebP quality for avatar optimization (1-100). 0 uses encoder default.
WEBP_QUALITY=0

# Encoding Worker Configuration (Server Mode)
# Enable encoding workers within the server process
ENABLE_ENCODING=false
# Number of encoding worker goroutines
ENCODING_WORKERS=2
# Keep original uploaded file after transcoding
# KEEP_ORIGINAL_FILE=true
# Metrics server address for encoding metrics
METRICS_ADDR=:9090

# API Configuration (optional)
# API_TIMEOUT=60
# API_MAX_REQUEST_SIZE=10MB
# API_PAGINATION_DEFAULT_LIMIT=20
# API_PAGINATION_MAX_LIMIT=100

# Validation Configuration (optional)
# VALIDATION_STRICT_MODE=false
# VALIDATION_ALLOWED_ALGORITHMS=sha256
# VALIDATION_TEST_MODE=false
# VALIDATION_ENABLE_INTEGRITY_JOBS=true
# VALIDATION_LOG_EVENTS=true

# Storage Tiers (optional)
# HOT_STORAGE_LIMIT=100GB
# WARM_STORAGE_LIMIT=1TB
# COLD_STORAGE_ENABLED=true

# Pinning Strategy (optional)
# PINNING_REPLICATION_FACTOR=3
# PINNING_SCORE_THRESHOLD=0.3
# PINNING_BACKUP_ENABLED=true

# Nginx Reverse Proxy (configured by setup wizard)
# NGINX_ENABLED=true
# NGINX_DOMAIN=localhost
# NGINX_PORT=80
# NGINX_PROTOCOL=http
# NGINX_TLS_MODE=                         # self-signed or letsencrypt (only when NGINX_PROTOCOL=https)
# NGINX_LETSENCRYPT_EMAIL=                # Required when NGINX_TLS_MODE=letsencrypt

# Public URL (for embeds/links)
# Automatically populated by setup wizard from nginx config
# PUBLIC_BASE_URL=

# ATProto Integration (optional)
# ENABLE_ATPROTO=false
# ATPROTO_PDS_URL=
# ATPROTO_AUTH_TOKEN=
# ATPROTO_HANDLE=
# ATPROTO_APP_PASSWORD=
# ATPROTO_TOKEN_KEY=
# ATPROTO_REFRESH_INTERVAL_SECONDS=2700
# ATPROTO_USE_IMAGE_EMBED=false
# ATPROTO_IMAGE_ALT_FIELD=description
# ATPROTO_SYNC_ENABLED=false
# ATPROTO_SYNC_PUBLIC_ONLY=true
# ATPROTO_MAX_RETRIES=3
# ATPROTO_RETRY_BASE_DELAY_MS=500

# Federation Scheduler (optional)
# ENABLE_FEDERATION_SCHEDULER=true
# FEDERATION_SCHEDULER_INTERVAL_SECONDS=15
# FEDERATION_SCHEDULER_BURST=1
# FEDERATION_INGEST_INTERVAL_SECONDS=60
# FEDERATION_INGEST_MAX_ITEMS=40
# FEDERATION_INGEST_MAX_PAGES=2

# ATProto Labeler (optional)
# ENABLE_ATPROTO_LABELER=false

# ATProto Firehose (optional)
# ENABLE_ATPROTO_FIREHOSE=false
# ATPROTO_FIREHOSE_POLL_INTERVAL_SECONDS=5

# ActivityPub (optional)
# ENABLE_ACTIVITYPUB=false
# ACTIVITYPUB_DOMAIN=
# ACTIVITYPUB_DELIVERY_WORKERS=5
# ACTIVITYPUB_DELIVERY_RETRIES=10
# ACTIVITYPUB_DELIVERY_RETRY_DELAY=60
# ACTIVITYPUB_ACCEPT_FOLLOW_AUTOMATIC=true
# ACTIVITYPUB_INSTANCE_DESCRIPTION=A PeerTube-compatible video platform
# ACTIVITYPUB_INSTANCE_CONTACT_EMAIL=
# ACTIVITYPUB_MAX_ACTIVITIES_PER_PAGE=20
# ACTIVITYPUB_KEY_ENCRYPTION_KEY=change-this-to-a-secure-random-key-at-least-32-characters-long
# CRITICAL: This key is used to encrypt ActivityPub private keys at rest in the database
# Use a strong random key (e.g., generated with: openssl rand -base64 48)

# =============================================================================
# ClamAV Virus Scanning Configuration (REQUIRED FOR PRODUCTION)
# =============================================================================
# ClamAV provides mandatory virus/malware scanning for all file uploads
# This is a critical security component - DO NOT disable in production

# ClamAV server address (host:port)
# Default: clamav:3310 (Docker Compose service name)
CLAMAV_ADDRESS=clamav:3310

# Scan timeout in seconds (300s = 5 minutes for large files)
# Increase for very large video files (>1GB)
CLAMAV_TIMEOUT=300

# Maximum retry attempts for ClamAV connection failures
# Helps handle temporary ClamAV signature loading delays
CLAMAV_MAX_RETRIES=3

# Fallback mode when ClamAV is unavailable
# - "strict": Block all uploads (RECOMMENDED for production)
# - "warn": Allow uploads but log warnings (development only)
# - "skip": Skip scanning entirely (DANGEROUS - never use in production)
CLAMAV_FALLBACK_MODE=strict

# Quarantine directory for infected files
# Files detected as malware are moved here for forensic analysis
QUARANTINE_DIR=/var/quarantine

# Auto-quarantine infected files (true/false)
# When true, infected files are automatically moved to QUARANTINE_DIR
# When false, files are deleted immediately
CLAMAV_AUTO_QUARANTINE=true

# Audit log path for virus scan results
# Logs all scan results (clean, infected, errors) for compliance/security audit
CLAMAV_AUDIT_LOG=/var/log/vidra/virus_scan.log

# Enable verbose ClamAV logging (development/debugging)
# CLAMAV_VERBOSE=false

# =============================================================================
# Three SMTP Modes:
# 1. Dev Mode (Mailpit): SMTP_HOST=mailpit, SMTP_PORT=1025 (bundled in Docker Compose)
# 2. External Relay (Production): SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587, SMTP_TLS=false
#    Compatible with: Amazon SES, Mailgun, Postmark, SendGrid, etc.
# 3. Self-Hosted: SMTP_HOST=your-mail-server.com, SMTP_PORT=465, SMTP_TLS=true
# =============================================================================

# =============================================================================
# Redis TLS (optional)
# =============================================================================
# REDIS_TLS=false
# REDIS_TLS_INSECURE=false

# =============================================================================
# Health Check Timeouts (seconds)
# =============================================================================
# HEALTH_CHECK_TIMEOUT=30
# DB_PING_TIMEOUT=5
# REDIS_PING_TIMEOUT=3
# IPFS_PING_TIMEOUT=10

# =============================================================================
# Video Encoding Options
# =============================================================================
# Comma-separated quality levels
# VIDEO_QUALITIES=360p,480p,720p,1080p
# HLS segment duration in seconds
# HLS_SEGMENT_DURATION=4
# Number of thumbnails to generate
# THUMBNAIL_COUNT=3
# Comma-separated codecs (h264)
# VIDEO_CODECS=h264
# VP9 encoding
# ENABLE_VP9=false
# VP9_QUALITY=31
# VP9_SPEED=2
# AV1 encoding
# ENABLE_AV1=false
# AV1_PRESET=6
# AV1_CRF=30
# Codec priority: "speed" or "quality"
# CODEC_PRIORITY=speed

# =============================================================================
# Whisper / Auto-Captioning
# =============================================================================
# ENABLE_CAPTION_GENERATION=false
# Provider: "local" (whisper.cpp), "http" (whisper HTTP API), "openai-api"
# WHISPER_PROVIDER=local
# WHISPER_MODEL_SIZE=base
# WHISPER_CPP_PATH=/usr/local/bin/whisper
# WHISPER_API_URL=
# WHISPER_MODELS_DIR=/var/lib/whisper/models
# WHISPER_OPENAI_API_KEY=
# WHISPER_TEMP_DIR=/tmp/whisper
# CAPTION_GENERATION_WORKERS=2
# AUTO_CAPTION_FORMAT=vtt
# AUTO_CAPTION_LANGUAGE=

# =============================================================================
# Live Streaming (RTMP)
# =============================================================================
# ENABLE_LIVE_STREAMING=false
# RTMP_HOST=0.0.0.0
# RTMP_PORT=1935
# RTMP_MAX_CONNECTIONS=100
# RTMP_CHUNK_SIZE=4096
# RTMP_READ_TIMEOUT=30
# RTMP_WRITE_TIMEOUT=30
# MAX_STREAM_DURATION=0
# HLS_OUTPUT_DIR=./storage/live
# LIVE_HLS_SEGMENT_LENGTH=2
# LIVE_HLS_WINDOW_SIZE=10
# HLS_CLEANUP_INTERVAL=10
# HLS_VARIANTS=1080p,720p,480p,360p
# FFMPEG_PRESET=veryfast
# FFMPEG_TUNE=zerolatency
# MAX_CONCURRENT_TRANSCODES=10

# Live Stream Replay
# ENABLE_REPLAY_CONVERSION=true
# REPLAY_STORAGE_DIR=./storage/replays
# REPLAY_UPLOAD_TO_IPFS=true
# REPLAY_RETENTION_DAYS=30

# =============================================================================
# BitTorrent / WebTorrent Distribution
# =============================================================================
# ENABLE_TORRENTS=true
# TORRENT_LISTEN_PORT=6881
# TORRENT_MAX_CONNECTIONS=200
# TORRENT_UPLOAD_RATE_LIMIT=0
# TORRENT_DOWNLOAD_RATE_LIMIT=0
# TORRENT_SEED_RATIO=2.0
# TORRENT_DATA_DIR=./storage/torrents
# TORRENT_CACHE_SIZE=67108864
# TORRENT_TRACKER_URL=
# TORRENT_WEBSOCKET_TRACKER_URL=

# DHT
# ENABLE_DHT=true
# DHT_ANNOUNCE_INTERVAL=1800
# DHT_MAX_PEERS=500
# ENABLE_PEX=true

# WebTorrent
# ENABLE_WEBTORRENT=true
# WEBTORRENT_TRACKER_PORT=8000

# Smart Seeding
# SMART_SEEDING_ENABLED=true
# SMART_SEEDING_MIN_SEEDERS=3
# SMART_SEEDING_MAX_TORRENTS=100
# SMART_SEEDING_PRIORITIZE_VIEWS=true

# Hybrid Distribution (IPFS + WebTorrent)
# HYBRID_DISTRIBUTION_ENABLED=true
# HYBRID_PREFER_IPFS=false
# HYBRID_FALLBACK_TIMEOUT=10

# =============================================================================
# Backup Configuration
# =============================================================================
# BACKUP_ENABLED=false
# BACKUP_SCHEDULE=0 2 * * *
# BACKUP_RETENTION=7
# BACKUP_INCLUDE_DB=true
# BACKUP_INCLUDE_REDIS=true
# BACKUP_INCLUDE_STORAGE=true
# BACKUP_EXCLUDE_DIRS=
# BACKUP_TARGET=local

# Backup S3 (when BACKUP_TARGET=s3)
# BACKUP_S3_BUCKET=
# BACKUP_S3_PREFIX=backups/
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_REGION=us-east-1

# Backup SFTP (when BACKUP_TARGET=sftp)
# BACKUP_SFTP_HOST=
# BACKUP_SFTP_PORT=22
# BACKUP_SFTP_USER=
# BACKUP_SFTP_PASSWORD=
# BACKUP_SFTP_KEY_PATH=
# BACKUP_SFTP_PATH=/backups
# BACKUP_SFTP_HOST_KEY=

# =============================================================================
# Virus Scanning (overrides for ClamAV section below)
# =============================================================================
# VIRUS_SCAN_ENABLED=true
# VIRUS_SCAN_TIMEOUT=300
# VIRUS_SCAN_FALLBACK=false
# FILE_TYPE_BLOCKING_ENABLED=true

# =============================================================================
# SMTP Email Configuration
# =============================================================================
# Email support for user verification, password reset, and notifications

# Enable email functionality (true/false)
ENABLE_EMAIL=false

# SMTP transport type: "smtp" (default) or "sendmail"
SMTP_TRANSPORT=smtp

# Sendmail binary path (only used when SMTP_TRANSPORT=sendmail)
SMTP_SENDMAIL_PATH=/usr/sbin/sendmail

# SMTP server hostname
# Dev: "mailpit" (when app runs in Docker Compose) or "localhost" (when app runs locally)
# Production: Your SMTP relay hostname (e.g., smtp.mailgun.org)
SMTP_HOST=mailpit

# SMTP server port
# 1025: Mailpit (dev), 587: STARTTLS (relay), 465: Implicit TLS (self-hosted), 25: Plain (legacy)
SMTP_PORT=1025

# SMTP authentication credentials
SMTP_USERNAME=
SMTP_PASSWORD=

# Force TLS connection (implicit TLS on port 465)
# Set to true for port 465, false for port 587 STARTTLS
SMTP_TLS=false

# Disable STARTTLS upgrade on port 587 (use only for local dev servers like Mailpit)
SMTP_DISABLE_STARTTLS=false

# Custom CA certificate file path (for self-signed certs)
# SMTP_CA_FILE=/etc/ssl/certs/smtp-ca.pem

# Email sender configuration
SMTP_FROM=no-reply@vidra.local
SMTP_FROM_NAME=Vidra Core
