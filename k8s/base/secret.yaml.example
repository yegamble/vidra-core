# Example Kubernetes Secret configuration
# DO NOT commit this file with real credentials!
# Copy to secret.yaml and fill in actual values, then apply with kubectl

apiVersion: v1
kind: Secret
metadata:
  name: athena-secrets
  labels:
    app: athena
type: Opaque
stringData:
  # Database connection string
  # Format: postgres://username:password@host:port/database?sslmode=require
  database-url: "postgres://athena:CHANGE_ME@postgres:5432/athena?sslmode=require"

  # Redis connection string
  # Format: redis://[:password@]host:port/database
  redis-url: "redis://:CHANGE_ME@redis:6379/0"

  # JWT secret for token signing
  # Generate with: openssl rand -base64 64
  jwt-secret: "CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARACTERS"

  # HLS signing secret (optional, for private video streaming)
  # Generate with: openssl rand -base64 48
  hls-signing-secret: "CHANGE_ME_TO_A_LONG_RANDOM_STRING"

  # ActivityPub private key encryption key
  # Generate with: openssl rand -base64 48
  activitypub-key-encryption-key: "CHANGE_ME_TO_A_SECURE_RANDOM_KEY_AT_LEAST_32_CHARS"

  # S3-compatible storage credentials (if using S3)
  s3-access-key: ""
  s3-secret-key: ""

  # IOTA payment encryption key (if using IOTA)
  iota-encryption-key: ""

---
# Alternative: Use External Secrets Operator or Sealed Secrets
# Example with External Secrets Operator:
#
# apiVersion: external-secrets.io/v1beta1
# kind: ExternalSecret
# metadata:
#   name: athena-secrets
# spec:
#   refreshInterval: 1h
#   secretStoreRef:
#     name: aws-secrets-manager  # or vault, etc.
#     kind: SecretStore
#   target:
#     name: athena-secrets
#     creationPolicy: Owner
#   data:
#   - secretKey: database-url
#     remoteRef:
#       key: athena/database-url
#   - secretKey: redis-url
#     remoteRef:
#       key: athena/redis-url
#   - secretKey: jwt-secret
#     remoteRef:
#       key: athena/jwt-secret
