{
  "info": {
    "name": "Vidra Core Video Studio API",
    "_postman_id": "d7e7d7e7-0007-4000-9000-d7e7d7e7d7e7",
    "description": "Postman collection for PeerTube-compatible video studio editing endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "['video_id', 'access_token'].forEach(function(key) {",
          "  var envVal = pm.environment.get(key);",
          "  if (envVal) { pm.collectionVariables.set(key, envVal); }",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "video_id", "value": "", "type": "string"},
    {"key": "studio_job_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Studio Edit - Happy Path",
      "item": [
        {
          "name": "POST /api/v1/videos/:id/studio/edit - Create cut job",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is acceptable', () => {",
            "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
            "});",
            "if (pm.response.code >= 200 && pm.response.code < 300) {",
            "  const body = pm.response.json();",
            "  pm.test('Response has job ID', () => {",
            "    pm.expect(body.success).to.be.true;",
            "    pm.expect(body.data.id).to.be.a('string');",
            "    pm.expect(['pending', 'processing', 'completed']).to.include(body.data.status);",
            "    pm.collectionVariables.set('studio_job_id', body.data.id);",
            "  });",
            "}"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"tasks\": [\n    {\"name\": \"cut\", \"options\": {\"start\": 5, \"end\": 30}}\n  ]\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/studio/edit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "studio", "edit"]}
          }
        },
        {
          "name": "GET /api/v1/videos/:id/studio/jobs - List jobs",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is acceptable', () => {",
            "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/studio/jobs", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "studio", "jobs"]}
          }
        },
        {
          "name": "GET /api/v1/videos/:id/studio/jobs/:jobId - Get job",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is acceptable', () => {",
            "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
            "});",
            "if (pm.response.code >= 200 && pm.response.code < 300) {",
            "  const body = pm.response.json();",
            "  pm.test('Response has job data', () => {",
            "    pm.expect(body.success).to.be.true;",
            "    pm.expect(body.data.id).to.equal(pm.collectionVariables.get('studio_job_id'));",
            "  });",
            "}"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/studio/jobs/{{studio_job_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "studio", "jobs", "{{studio_job_id}}"]}
          }
        }
      ]
    },
    {
      "name": "Studio Edit - Error Cases",
      "item": [
        {
          "name": "POST /studio/edit - Empty tasks",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is acceptable error', () => {",
            "  pm.expect([400, 403, 404, 405, 500]).to.include(pm.response.code);",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"tasks\": []\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/studio/edit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "studio", "edit"]}
          }
        },
        {
          "name": "POST /studio/edit - Unknown task name",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is acceptable error', () => {",
            "  pm.expect([400, 403, 404, 405, 500]).to.include(pm.response.code);",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"tasks\": [{\"name\": \"rotate\", \"options\": {}}]\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/studio/edit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "studio", "edit"]}
          }
        },
        {
          "name": "POST /studio/edit - No auth",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is acceptable error', () => {",
            "  pm.expect([400, 401, 403, 404, 405, 500]).to.include(pm.response.code);",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"tasks\": [{\"name\": \"cut\", \"options\": {\"start\": 0, \"end\": 10}}]\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/studio/edit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "studio", "edit"]}
          }
        }
      ]
    }
  ]
}
