    {
      "name": "Comments (Authenticated)",
      "description": "Create and delete ATProto comment records with threaded reply support.",
      "item": [
        {
          "name": "Create Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"actor_did\": \"{{test_did}}\",\n  \"text\": \"Great video! Really well explained.\",\n  \"root_uri\": \"{{test_uri}}\",\n  \"root_cid\": \"bafyreib2rxk3rybk3aobmv5cjuql3bm2twh4jo5uxgf5kpqcsgz7soitxq\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/social/comment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "social", "comment"]
            },
            "description": "Create a top-level comment on a video post URI."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('response is 201 or 401 or 500', function() {",
                  "    pm.expect([201, 401, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.test('comment has uri field', function() {",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.nested.property('data');",
