              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "social", "moderation", "label", "{{label_id}}"]
            },
            "description": "Remove a moderation label by its ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('response is 200 or 401 or 500', function() {",
