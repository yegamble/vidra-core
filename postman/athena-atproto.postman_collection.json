{
  "info": {
    "name": "Athena ATProto / Social API",
    "description": "ATProto (BlueSky) social graph and moderation API E2E tests.\n\nCovers all 17 endpoints under /api/v1/social/*:\n- Actor resolution and statistics (public)\n- Social graph: followers, following (public reads, authenticated writes)\n- Likes: create, delete, list\n- Comments: create, get, thread, delete\n- Moderation: apply label, get labels, remove label\n- Feed ingest from ATProto PDS\n\n**IPFS note:** IPFS-backed avatar uploads are exercised by the auth endpoints\n(PUT /api/v1/users/me/avatar). Those requests pass avatarUrl which may be\nresolved via IPFS if an IPFS gateway is configured. To exercise the full IPFS\npath, set IPFS_GATEWAY in the server environment and upload an avatar using\nthe athena-auth collection. The IPFS CID is returned in the response.\n\n**ATProto Go test coverage:** PublishVideo, PublishComment, and PublishVideoBatch\nare covered by unit tests in internal/usecase/atproto_features_test.go with a\nmocked PDS HTTP server. Those tests pass without an external ATProto PDS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token from login"
    },
    {
      "key": "test_handle",
      "value": "alice.bsky.social",
      "type": "string",
      "description": "AT Protocol handle for actor resolution tests"
    },
    {
      "key": "test_uri",
      "value": "at://did:plc:test/app.bsky.feed.post/test123",
      "type": "string",
      "description": "AT URI for likes/comments"
    },
    {
      "key": "test_did",
      "value": "did:plc:test123",
      "type": "string",
      "description": "DID for moderation label tests"
    },
    {
      "key": "comment_uri",
      "value": "",
      "type": "string",
      "description": "URI of created comment (set during run)"
    },
    {
      "key": "label_id",
      "value": "",
      "type": "string",
      "description": "ID of created moderation label (set during run)"
    }
  ],
  "item": [
    {
      "name": "Actor Discovery (Public)",
      "description": "Public read endpoints for ATProto actor resolution — no auth required.",
      "item": [
        {
          "name": "Get Actor by Handle",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/social/actors/{{test_handle}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "social", "actors", "{{test_handle}}"]
            },
            "description": "Resolve an ATProto actor by handle. Returns actor DID, profile, and metadata.\nReturns 404 if handle is not found in the ATProto PDS."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Accept 200 (actor found) or 404 (not in PDS — expected in test env)",
                  "pm.test('response is 200 or 404', function() {",
                  "    pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('response has json body', function() {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('actor has data field', function() {",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.property('data');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
