    {
      "name": "Social Graph (Authenticated)",
      "description": "Follow / unfollow operations. Requires a valid JWT access_token.",
      "item": [
        {
          "name": "Follow Actor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"target\": \"{{test_handle}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/social/follow",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "social", "follow"]
            },
            "description": "Follow an ATProto actor by handle or DID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('response is 200 or 401 or 500', function() {",
                  "    // 401 if no valid token; 500 if PDS not available in test env",
                  "    pm.expect([200, 401, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('response is json', function() {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('success response has status field', function() {",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.nested.property('data.status');",
                  "        pm.expect(body.data.status).to.equal('followed');",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
