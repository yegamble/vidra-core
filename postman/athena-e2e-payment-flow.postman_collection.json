{
  "info": {
    "name": "Athena E2E: Payment Flow",
    "description": "End-to-end IOTA payment workflow: create wallets, create payment intent, check status, view transaction history.\n\nThis collection tests the complete payment lifecycle.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n\n## Variables Set During Run\n- `e2e_pay_sender_token` - Sender JWT access token\n- `e2e_pay_receiver_token` - Receiver JWT access token\n- `e2e_pay_intent_id` - Created payment intent UUID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup: Register Sender",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now();",
              "pm.environment.set('e2e_pay_sender_user', 'paysender_' + ts);",
              "pm.environment.set('e2e_pay_sender_email', 'paysender_' + ts + '@example.com');",
              "pm.environment.set('e2e_pay_receiver_user', 'payrecv_' + ts);",
              "pm.environment.set('e2e_pay_receiver_email', 'payrecv_' + ts + '@example.com');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('e2e_pay_sender_token', body.data.access_token);",
              "pm.environment.set('e2e_pay_sender_id', body.data.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{e2e_pay_sender_user}}\",\n  \"email\": \"{{e2e_pay_sender_email}}\",\n  \"password\": \"E2ePayPass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "Setup: Register Receiver",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('e2e_pay_receiver_token', body.data.access_token);",
              "pm.environment.set('e2e_pay_receiver_id', body.data.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{e2e_pay_receiver_user}}\",\n  \"email\": \"{{e2e_pay_receiver_email}}\",\n  \"password\": \"E2ePayPass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "Create Wallet (sender)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 201', () => {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Wallet created', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "  pm.expect(body.data).to.have.property('address');",
              "});",
              "pm.environment.set('e2e_pay_sender_address', body.data.address);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_pay_sender_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/payments/wallet",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "payments", "wallet"]
        }
      },
      "response": []
    },
    {
      "name": "Create Wallet (receiver)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 201', () => {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Wallet created', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "  pm.expect(body.data).to.have.property('address');",
              "});",
              "pm.environment.set('e2e_pay_receiver_address', body.data.address);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_pay_receiver_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/payments/wallet",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "payments", "wallet"]
        }
      },
      "response": []
    },
    {
      "name": "Create Payment Intent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 201', () => {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Payment intent created', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "  pm.expect(body.data).to.have.property('id');",
              "});",
              "pm.environment.set('e2e_pay_intent_id', body.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_pay_sender_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiver_id\": \"{{e2e_pay_receiver_id}}\",\n  \"amount\": 1000000,\n  \"description\": \"E2E test payment\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/payments/intents",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "payments", "intents"]
        }
      },
      "response": []
    },
    {
      "name": "Get Payment Intent (verify pending)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Intent status returned', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "  pm.expect(body.data).to.have.property('id');",
              "  pm.expect(body.data).to.have.property('status');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_pay_sender_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/payments/intents/{{e2e_pay_intent_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "payments", "intents", "{{e2e_pay_intent_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Get Transaction History",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Transaction history returned', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_pay_sender_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/payments/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "payments", "transactions"]
        }
      },
      "response": []
    }
  ]
}
