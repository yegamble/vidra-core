{
  "info": {
    "name": "Vidra Core Live Stream Chat API",
    "description": "Test collection for live stream chat: messages, moderators, bans.\n\nUses /api/v1/streams/{streamId}/chat/* endpoints.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `access_token` - JWT access token\n- `admin_access_token` - Admin JWT access token\n\n## Variables Set During Run\n- `chat_stream_id` - UUID of created stream\n- `chat_message_id` - UUID of sent message\n- `chat_ban_user_id` - UUID of banned user",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "['access_token', 'admin_access_token', 'channel_id'].forEach(function(key) { var envVal = pm.environment.get(key); if (envVal) { pm.collectionVariables.set(key, envVal); } });"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://app-test:8080",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "chat_stream_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "chat_message_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Create Stream (setup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is acceptable', () => {",
                  "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Stream created with ID', () => {",
                  "    pm.expect(body).to.have.property('success', true);",
                  "    pm.expect(body.data).to.have.property('id');",
                  "  });",
                  "  pm.environment.set('chat_stream_id', body.data.id);",
                  "  console.log('Stream ID:', body.data.id);",
                  "  }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Chat Test Stream\",\n  \"description\": \"Stream for chat testing\",\n  \"channel_id\": \"{{channel_id}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/streams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "streams"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Chat Messages",
      "item": [
        {
          "name": "Get Chat Messages (empty)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is acceptable', () => {",
                  "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Empty messages list', () => {",
                  "    pm.expect(body).to.have.property('success', true);",
                  "  });",
                  "  }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/streams/{{chat_stream_id}}/chat/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "streams",
                "{{chat_stream_id}}",
                "chat",
                "messages"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Send Chat Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is acceptable', () => {",
                  "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Message sent successfully', () => {",
                  "    pm.expect(body).to.have.property('success', true);",
                  "    if (body.data && body.data.id) {",
                  "      pm.environment.set('chat_message_id', body.data.id);",
                  "    }",
                  "  });",
                  "  }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Hello from Postman chat test!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/streams/{{chat_stream_id}}/chat/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "streams",
                "{{chat_stream_id}}",
                "chat",
                "messages"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Messages (verify sent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is acceptable', () => {",
                  "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Messages returned', () => {",
                  "    pm.expect(body).to.have.property('success', true);",
                  "  });",
                  "  }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/streams/{{chat_stream_id}}/chat/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "streams",
                "{{chat_stream_id}}",
                "chat",
                "messages"
              ]
            }
          },
          "response": []
        }
      ]
    },
