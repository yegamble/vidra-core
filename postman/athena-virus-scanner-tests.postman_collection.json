    {
      "name": "02 - Breaking Scenarios (P1 Vulnerability)",
      "item": [
        {
          "name": "Exploit: Network Error During Scan",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This test simulates the P1 vulnerability scenario",
                  "console.log('======================================');",
                  "console.log('BREAKING TEST: Network Error During Scan');",
                  "console.log('======================================');",
                  "console.log('Scenario: Upload infected file with ClamAV network interruption');",
                  "console.log('BEFORE FIX: File bypasses scanning and gets processed');",
                  "console.log('AFTER FIX: File is rejected or quarantined');",
                  "console.log('');",
                  "",
                  "const timestamp = Date.now();",
                  "pm.environment.set('test_timestamp', timestamp);",
                  "",
                  "// Note: This test requires ClamAV to be temporarily unavailable",
                  "// or network interruption during scanning",
                  "console.log('Manual Test Steps:');",
                  "console.log('1. Start upload of EICAR test file');",
                  "console.log('2. Interrupt ClamAV connection mid-scan');",
                  "console.log('3. Verify file is rejected (not accepted with warning)');",
                  "console.log('');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Critical security test: Infected file should NEVER be accepted",
                  "pm.test('[CRITICAL] Infected file is rejected', () => {",
                  "    // Should be 400, 403, or 500 - never 201 or 200",
                  "    const rejectedCodes = [400, 403, 500, 503];",
                  "    pm.expect(rejectedCodes).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('[CRITICAL] No fallback mode used for infected files', () => {",
                  "    if (pm.response.code === 201 || pm.response.code === 200) {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.data).to.not.have.property('fallback_used');",
                  "        // If this test fails, the P1 vulnerability still exists",
                  "    }",
                  "});",
                  "",
                  "if (pm.response.code >= 400) {",
                  "    pm.test('Error indicates virus scan failure', () => {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.error).to.exist;",
                  "        // Should mention scanning or virus detection",
                  "        const errorLower = JSON.stringify(response.error).toLowerCase();",
                  "        const hasScanKeyword = errorLower.includes('scan') || ",
                  "                               errorLower.includes('virus') || ",
                  "                               errorLower.includes('malware') ||",
                  "                               errorLower.includes('clamav');",
                  "        pm.expect(hasScanKeyword).to.be.true;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/octet-stream",
                "type": "text"
              },
              {
                "key": "X-Filename",
                "value": "eicar-test-{{test_timestamp}}.txt",
                "type": "text"
              },
              {
                "key": "X-Virus-Test",
                "value": "true",
                "type": "text",
                "description": "Flag to indicate this is a virus test"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "X5O!P%@AP[4\\PZX54(P^)7CC)7}$EICAR-STANDARD-ANTIVIRUS-TEST-FILE!$H+H*"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/uploads/direct",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "uploads", "direct"]
            },
            "description": "Attempts to upload EICAR test virus. Should be blocked even if network interruption occurs."
          }
        },
        {
          "name": "Exploit: Retry Exhaustion",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log('Testing retry exhaustion scenario');",
                  "console.log('Scenario: ClamAV unavailable for all retry attempts');",
                  "console.log('Expected: File is rejected with error (strict mode)');",
                  "",
                  "pm.collectionVariables.set('scan_attempts', 0);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[CRITICAL] Scan failure results in rejection', () => {",
                  "    // In strict mode, should never accept file if scan fails",
                  "    pm.expect([500, 503]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('Error indicates scan service unavailable', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('error');",
                  "    const errorLower = JSON.stringify(response.error).toLowerCase();",
                  "    const hasServiceError = errorLower.includes('unavailable') ||",
                  "                           errorLower.includes('failed') ||",
                  "                           errorLower.includes('scan');",
                  "    pm.expect(hasServiceError).to.be.true;",
                  "});",
                  "",
                  "pm.test('No file accepted without successful scan', () => {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.not.have.nested.property('data.session_id');",
                  "    pm.expect(response).to.not.have.nested.property('data.video_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Test-ClamAV-Unavailable",
                "value": "true",
                "type": "text",
                "description": "Test header to simulate ClamAV unavailability"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"test-retry-exhaustion.mp4\",\n  \"file_size\": 1048576,\n  \"chunk_size\": 524288,\n  \"video_metadata\": {\n    \"title\": \"Retry Exhaustion Test\",\n    \"description\": \"Testing scan failure with exhausted retries\",\n    \"privacy\": \"private\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/uploads/initiate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "uploads", "initiate"]
            }
          }
        },
        {
          "name": "Exploit: Concurrent Infected Uploads",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "console.log('Testing concurrent infected file uploads');",
                  "console.log('Expected: All infected files rejected');",
                  "console.log('Checks for: Race conditions, scanning queue overflow');",
                  "",
                  "// Note: Run this test multiple times in parallel to test race conditions",
                  "const timestamp = Date.now();",
                  "const randomId = Math.floor(Math.random() * 1000);",
                  "pm.environment.set('test_id', `${timestamp}-${randomId}`);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('[CRITICAL] Infected file rejected even under load', () => {",
                  "    // Should always reject infected files, even under concurrent load",
                  "    pm.expect([400, 403, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('No race condition allows infected file through', () => {",
                  "    if (pm.response.code === 201 || pm.response.code === 200) {",
                  "        // This should NEVER happen with infected files",
                  "        throw new Error('SECURITY FAILURE: Infected file accepted under concurrent load');",
                  "    }",
                  "});",
                  "",
                  "pm.test('Response time acceptable under load', () => {",
                  "    // Should respond within 30 seconds even under load",
                  "    pm.expect(pm.response.responseTime).to.be.below(30000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/octet-stream",
                "type": "text"
              },
              {
                "key": "X-Filename",
                "value": "eicar-concurrent-{{test_id}}.txt",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "X5O!P%@AP[4\\PZX54(P^)7CC)7}$EICAR-STANDARD-ANTIVIRUS-TEST-FILE!$H+H*"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/uploads/direct",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "uploads", "direct"]
            }
          }
        }
      ]
