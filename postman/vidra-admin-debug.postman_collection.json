              "raw": "{{baseUrl}}/api/v1/admin/jobs/completed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "jobs", "completed"]
            }
          },
          "response": []
        },
        {
          "name": "List Instance Configs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200, 403, or 404', () => {",
                  "  pm.expect([200, 403, 404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
