{
  "info": {
    "name": "Vidra Core Admin Debug & Logs API",
    "description": "Test collection for admin-level debug info, server stats, and instance management.\n\nUses admin endpoints for server introspection.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `admin_access_token` - Admin JWT access token\n- `access_token` - Regular user JWT access token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Instance Info",
      "item": [
        {
          "name": "Get Instance About",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('About info returned', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/instance/about",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "instance", "about"]
            }
          },
          "response": []
        },
        {
          "name": "Get Instance Stats",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Stats returned', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/instance/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "instance", "stats"]
            }
          },
          "response": []
        }
      ]
    },
    {
