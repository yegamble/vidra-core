{
  "info": {
    "name": "Vidra Core Admin Debug & Logs API",
    "description": "Test collection for admin-level debug info, server stats, and instance management.\n\nUses admin endpoints for server introspection.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `admin_access_token` - Admin JWT access token\n- `access_token` - Regular user JWT access token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "['access_token', 'admin_access_token'].forEach(function(key) {",
          "  var envVal = pm.environment.get(key);",
          "  if (envVal) {",
          "    pm.collectionVariables.set(key, envVal);",
          "  }",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "admin_access_token", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Instance Info",
      "item": [
        {
          "name": "Get Instance About",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('About info returned', () => {",
                  "    pm.expect(body.instance || body.success).to.be.ok;",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/instance/about",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "instance", "about"]
            }
          },
          "response": []
        },
        {
          "name": "Get Instance Stats",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/instance/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "instance", "stats"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin Operations",
      "item": [
        {
          "name": "List Admin Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200, 403, or 404', () => {",
                  "  pm.expect([200, 403, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Users list returned', () => {",
                  "    pm.expect(body).to.have.property('success', true);",
                  "    if (body.data && body.data.data) {",
                  "      pm.expect(body.data.data).to.be.an('array');",
                  "    }",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"]
            }
          },
          "response": []
        },
        {
          "name": "List Admin Videos",
