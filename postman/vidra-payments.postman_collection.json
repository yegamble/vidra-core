{
  "info": {
    "name": "Vidra Core Bitcoin Payments API",
    "description": "Test collection for Bitcoin payments via BTCPay Server: invoice creation, retrieval, listing, and webhook processing.\n\n## Lifecycle\n\n1. **Create Invoice** — create a Bitcoin payment invoice\n2. **Get Invoice** — check invoice status\n3. **List Invoices** — list user's invoices with pagination\n4. **Webhook Callback** — simulate BTCPay Server webhook\n5. **Error cases** — auth failures, invalid amounts\n\n## Environment Variables Required\n\n- `baseUrl` - API base URL\n- `access_token` - JWT access token\n\n## Variables Set During Run\n\n- `invoice_id` - ID of the created invoice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function() { pm.response.to.have.status(201); });",
                  "pm.test('Response has invoice data', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('id');",
                  "  pm.expect(json.data).to.have.property('btcpay_invoice_id');",
                  "  pm.expect(json.data).to.have.property('amount_sats');",
                  "  pm.expect(json.data).to.have.property('status');",
                  "  pm.expect(json.data.status).to.equal('New');",
                  "  pm.collectionVariables.set('invoice_id', json.data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount_sats\": 100000,\n  \"currency\": \"BTC\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "invoices"] }
          }
        },
        {
          "name": "Create Invoice - Invalid Amount",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', function() { pm.response.to.have.status(400); });",
                  "pm.test('Error code is INVALID_AMOUNT', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.error.code).to.equal('INVALID_AMOUNT');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount_sats\": 0\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "invoices"] }
          }
        },
        {
          "name": "Create Invoice - Unauthorized",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', function() { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount_sats\": 100000\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "invoices"] }
          }
        },
        {
          "name": "Get Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response has invoice data', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('id');",
                  "  pm.expect(json.data).to.have.property('status');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices/{{invoice_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "invoices", "{{invoice_id}}"] }
          }
        },
        {
          "name": "Get Invoice - Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', function() { pm.response.to.have.status(404); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "invoices", "00000000-0000-0000-0000-000000000000"] }
          }
        },
        {
          "name": "List Invoices",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response is array', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices?count=15&start=0", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "invoices"], "query": [{"key": "count", "value": "15"}, {"key": "start", "value": "0"}] }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "BTCPay Webhook - Invoice Settled",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "BTCPay-Sig", "value": "" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"InvoiceSettled\",\n  \"invoiceId\": \"test-inv-id\",\n  \"storeId\": \"test-store-id\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/webhooks/btcpay", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "webhooks", "btcpay"] }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "invoice_id", "value": "" }
  ]
}
