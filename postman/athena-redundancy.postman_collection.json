{
  "info": {
    "name": "Athena Redundancy API",
    "description": "Test collection for redundancy management: instance peers, policies, video redundancies, and health stats.\n\nUses admin routes for redundancy management.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `admin_access_token` - Admin JWT access token\n\n## Variables Set During Run\n- `redundancy_peer_id` - UUID of registered peer\n- `redundancy_policy_id` - UUID of created policy",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Instance Peers",
      "item": [
        {
          "name": "List Instance Peers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Response has data', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/redundancy/peers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "redundancy", "peers"]
            }
          },
          "response": []
        },
        {
          "name": "Register Instance Peer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 201', () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Peer created', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body.data).to.have.property('id');",
                  "});",
                  "pm.environment.set('redundancy_peer_id', body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"instance_url\": \"https://peer-test.example.com\",\n  \"auto_accept_redundancy\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/redundancy/peers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "redundancy", "peers"]
            }
          },
          "response": []
        },
        {
          "name": "Get Peer Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Peer details returned', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body.data).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/redundancy/peers/{{redundancy_peer_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "redundancy", "peers", "{{redundancy_peer_id}}"]
            }
          },
          "response": []
        }
      ]
    },
