{
  "info": {
    "name": "Athena Live Streaming API",
    "_postman_id": "c6a6c6a6-0006-4000-9000-c6a6c6a6c6a6",
    "description": "Postman collection for live streaming: create/manage streams, session history, HLS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "stream_id", "value": "", "type": "string"},
    {"key": "channel_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Live Streaming - Happy Path",
      "item": [
        {
          "name": "POST /api/v1/streams - Create live stream",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 201 or 200', () => pm.expect([200, 201]).to.include(pm.response.code));",
            "const json = pm.response.json();",
            "if (json && json.id) pm.collectionVariables.set('stream_id', json.id);"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Test Live Stream {{$timestamp}}\",\n  \"channelId\": \"{{channel_id}}\",\n  \"privacy\": \"public\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/streams", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams"]}
          }
        },
        {
          "name": "GET /api/v1/streams/active - Active streams",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/active", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "active"]}
          }
        },
        {
          "name": "GET /api/v1/streams/:id - Get stream",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/{{stream_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "{{stream_id}}"]}
          }
        },
        {
          "name": "GET /api/v1/streams/:id/sessions - Session history",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has sessions array', () => pm.expect(json).to.satisfy(r => Array.isArray(r) || (r.data !== undefined && r.total !== undefined)));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/{{stream_id}}/sessions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "{{stream_id}}", "sessions"]}
          }
        },
        {
          "name": "GET /api/v1/streams/:id/stats - Stream stats",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/{{stream_id}}/stats", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "{{stream_id}}", "stats"]}
          }
        },
        {
          "name": "GET /api/v1/streams/channels/:channelId - Channel streams",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/channels/{{channel_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "channels", "{{channel_id}}"]}
          }
        },
        {
          "name": "POST /api/v1/streams/:id/end - End stream",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200 or 204', () => pm.expect([200, 204]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/{{stream_id}}/end", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "{{stream_id}}", "end"]}
          }
        }
      ]
    },
    {
      "name": "Live Streaming - Error Path",
      "item": [
        {
          "name": "POST /api/v1/streams - Unauthenticated (401)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 401', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Unauthorized Stream\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/streams", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams"]}
          }
        },
        {
          "name": "GET /api/v1/streams/:id/sessions - Unauthenticated (401)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 401', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/streams/{{stream_id}}/sessions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "streams", "{{stream_id}}", "sessions"]}
          }
        }
      ]
    }
  ]
}
