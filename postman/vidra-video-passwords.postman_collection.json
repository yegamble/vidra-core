{
  "info": {
    "name": "Vidra Core Video Passwords API",
    "description": "Test collection for password-protected video access: list, add, replace, and delete passwords.\n\nPeerTube-compatible video password endpoints.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `access_token` - JWT access token\n- `video_id` - UUID of an existing video",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Video Passwords (empty)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Response has data', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/passwords",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{video_id}}", "passwords"]
        }
      },
      "response": []
    },
    {
      "name": "Add Password to Video",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 201 or 204', () => {",
              "  pm.expect([200, 201, 204]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code !== 204) {",
              "  const body = pm.response.json();",
              "  pm.test('Password added', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"passwords\": [\"secretpass123\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/passwords",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{video_id}}", "passwords"]
        }
      },
      "response": []
    },
    {
      "name": "List Passwords (verify added)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Passwords returned', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/passwords",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{video_id}}", "passwords"]
        }
      },
      "response": []
    },
    {
      "name": "Replace All Passwords",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 204', () => {",
              "  pm.expect([200, 204]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"passwords\": [\"newpass456\", \"anotherpass789\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/passwords",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{video_id}}", "passwords"]
        }
      },
      "response": []
    },
    {
      "name": "Access Video with Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Video data returned', () => {",
              "  pm.expect(body).to.have.property('success', true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-video-password", "value": "newpass456", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{video_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Delete All Passwords",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 204', () => {",
              "  pm.expect([200, 204]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"passwords\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/passwords",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{video_id}}", "passwords"]
        }
      },
      "response": []
    }
  ]
}
