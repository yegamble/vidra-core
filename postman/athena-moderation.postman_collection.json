{
  "info": {
    "name": "Athena Moderation API",
    "_postman_id": "c8a8c8a8-0008-4000-9000-c8a8c8a8c8a8",
    "description": "Postman collection for abuse reports, admin moderation, and abuse report discussion threads.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "abuse_id", "value": "", "type": "string"},
    {"key": "message_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Abuse Reports - Happy Path",
      "item": [
        {
          "name": "POST /api/v1/abuse-reports - Create abuse report",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 201 or 200', () => pm.expect([200, 201]).to.include(pm.response.code));",
            "const json = pm.response.json();",
            "if (json && json.id) pm.collectionVariables.set('abuse_id', json.id);"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"reason\": \"spam\",\n  \"videoId\": \"test-video-id\",\n  \"comment\": \"This video is spam\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/abuse-reports", "host": ["{{baseUrl}}"], "path": ["api", "v1", "abuse-reports"]}
          }
        },
        {
          "name": "GET /api/v1/admin/abuse-reports - List abuse reports (admin)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Response is array or has data', () => pm.expect(json).to.satisfy(r => Array.isArray(r) || r.data !== undefined));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports"]}
          }
        },
        {
          "name": "GET /api/v1/admin/abuse-reports/:id - Get single report",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports/{{abuse_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports", "{{abuse_id}}"]}
          }
        },
        {
          "name": "GET /api/v1/admin/abuse-reports/:id/messages - List messages",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has data and total', () => {",
            "  pm.expect(json).to.have.property('data');",
            "  pm.expect(json).to.have.property('total');",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports/{{abuse_id}}/messages", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports", "{{abuse_id}}", "messages"]}
          }
        },
        {
          "name": "POST /api/v1/admin/abuse-reports/:id/messages - Create message",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "if (json && json.id) pm.collectionVariables.set('message_id', json.id);"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"message\": \"Investigating this report.\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports/{{abuse_id}}/messages", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports", "{{abuse_id}}", "messages"]}
          }
        },
        {
          "name": "DELETE /api/v1/admin/abuse-reports/:id/messages/:msgId - Delete message",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports/{{abuse_id}}/messages/{{message_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports", "{{abuse_id}}", "messages", "{{message_id}}"]}
          }
        },
        {
          "name": "PUT /api/v1/admin/abuse-reports/:id - Update report state",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200 or 204', () => pm.expect([200, 204]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"state\": \"accepted\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports/{{abuse_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports", "{{abuse_id}}"]}
          }
        }
      ]
    },
    {
      "name": "Moderation - Error Path",
      "item": [
        {
          "name": "POST /api/v1/abuse-reports - Unauthenticated (401)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 401', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"reason\": \"spam\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/abuse-reports", "host": ["{{baseUrl}}"], "path": ["api", "v1", "abuse-reports"]}
          }
        },
        {
          "name": "GET /api/v1/admin/abuse-reports/:id/messages - Non-admin (401/403)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 401 or 403', () => pm.expect([401, 403]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/admin/abuse-reports/1/messages", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "abuse-reports", "1", "messages"]}
          }
        }
      ]
    }
  ]
}
