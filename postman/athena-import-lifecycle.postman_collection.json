              "listen": "test",
              "script": {
                "exec": [
                  "if (!pm.environment.get('import_job_id')) {",
                  "  console.log('No import_job_id — skipping cancel');",
                  "  return;",
                  "}",
                  "pm.test('Status is 200 or 400 (already terminal)', () => {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Cancel response has success', () => {",
                  "    pm.expect(body.success).to.be.true;",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
