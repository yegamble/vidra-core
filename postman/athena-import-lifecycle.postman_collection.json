          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetUrl\": \"http://192.168.1.1/evil\",\n  \"video\": {\"name\": \"SSRF attempt\"}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/imports",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "imports"]
            }
          },
          "response": []
        },
        {
          "name": "Create Import - No Auth (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
