    {
      "name": "Import Status",
      "item": [
        {
          "name": "Get Import Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (!pm.environment.get('import_job_id')) {",
                  "  console.log('No import_job_id set — skipping status check');",
                  "  return;",
                  "}",
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Import status fields', () => {",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('status');",
                  "  pm.expect(body).to.have.property('source_url');",
                  "  pm.expect(body).to.have.property('created_at');",
                  "});",
                  "pm.test('Status is valid enum', () => {",
                  "  const validStatuses = ['pending', 'downloading', 'processing', 'completed', 'failed', 'cancelled'];",
                  "  pm.expect(validStatuses).to.include(body.status);",
                  "});",
                  "console.log('Import', body.id, 'status:', body.status);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/imports/{{import_job_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "imports", "{{import_job_id}}"]
            },
            "description": "Get the status of a specific import job."
          },
          "response": []
        },
        {
          "name": "Get Import - Not Found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => {",
                  "  pm.expect(pm.response.code).to.equal(404);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Not found error structure', () => {",
                  "  pm.expect(body.success).to.be.false;",
                  "  pm.expect(body).to.have.property('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/imports/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "imports", "00000000-0000-0000-0000-000000000000"]
            }
          },
          "response": []
        }
      ]
    },
