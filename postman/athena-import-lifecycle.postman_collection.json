        {
          "name": "Retry Import - Pending State (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (!pm.environment.get('import_job_id')) { return; }",
                  "// Retrying a pending (not failed) import returns 400 — status must be 'failed'",
                  "pm.test('Status is 400 or 200', () => {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ],
