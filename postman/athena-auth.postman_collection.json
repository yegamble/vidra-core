                  "  pm.expect(meta).to.have.property('offset');",
                  "});",
                  "if (videos.length > 0) {",
                  "  pm.test('Videos have required fields', () => {",
                  "    const video = videos[0];",
                  "    pm.expect(video).to.have.property('id');",
                  "    pm.expect(video).to.have.property('title');",
                  "    pm.expect(video).to.have.property('privacy');",
                  "    pm.expect(video).to.have.property('status');",
