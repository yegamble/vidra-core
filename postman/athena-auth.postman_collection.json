          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const wrap = pm.response.json();",
                  "pm.test('Response wrapped with data', () => pm.expect(wrap).to.have.property('data'));",
                  "const json = wrap.data || {};",
                  "pm.test('Has user + tokens', () => {",
