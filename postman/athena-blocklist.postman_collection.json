{
  "info": {
    "name": "Athena Blocklist API",
    "_postman_id": "cababab-0010-4000-9000-cababababab",
    "description": "Postman collection for per-user blocklist: block/unblock accounts and servers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "block_account_id", "value": "", "type": "string"},
    {"key": "account_name", "value": "blockeduser", "type": "string"},
    {"key": "server_host", "value": "badinstance.example.com", "type": "string"}
  ],
  "item": [
    {
      "name": "Account Blocklist - Happy Path",
      "item": [
        {
          "name": "GET /api/v1/channels - Resolve block target account",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "const channels = json.data && Array.isArray(json.data.data) ? json.data.data : [];",
            "const currentUserId = pm.environment.get('user_id');",
            "const target = channels.find(ch => ch.accountId && ch.accountId !== currentUserId && ch.account && ch.account.username);",
            "pm.test('Found block target account', () => pm.expect(target).to.exist);",
            "if (target) {",
            "  pm.collectionVariables.set('block_account_id', target.accountId);",
            "  pm.collectionVariables.set('account_name', target.account.username);",
            "  pm.environment.set('block_account_id', target.accountId);",
            "  pm.environment.set('account_name', target.account.username);",
            "}"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/channels", "host": ["{{baseUrl}}"], "path": ["api", "v1", "channels"]}
          }
        },
        {
          "name": "POST /api/v1/blocklist/accounts - Block account",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 204 or 201', () => pm.expect([201, 204]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"accountId\": \"{{block_account_id}}\",\n  \"accountName\": \"{{account_name}}\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/accounts", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "accounts"]}
          }
        },
        {
          "name": "GET /api/v1/blocklist/accounts - List blocked accounts",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has data and meta total', () => {",
            "  pm.expect(json).to.have.property('data');",
            "  pm.expect(json).to.have.property('meta');",
            "  pm.expect(json.meta).to.have.property('total');",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/accounts", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "accounts"]}
          }
        },
        {
          "name": "DELETE /api/v1/blocklist/accounts/:accountName - Unblock account",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/accounts/{{account_name}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "accounts", "{{account_name}}"]}
          }
        }
      ]
    },
    {
      "name": "Server Blocklist - Happy Path",
      "item": [
        {
          "name": "POST /api/v1/blocklist/servers - Block server",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 204 or 201', () => pm.expect([201, 204]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"host\": \"{{server_host}}\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/servers", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "servers"]}
          }
        },
        {
          "name": "GET /api/v1/blocklist/servers - List blocked servers",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has data and meta total', () => {",
            "  pm.expect(json).to.have.property('data');",
            "  pm.expect(json).to.have.property('meta');",
            "  pm.expect(json.meta).to.have.property('total');",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/servers", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "servers"]}
          }
        },
        {
          "name": "DELETE /api/v1/blocklist/servers/:host - Unblock server",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/servers/{{server_host}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "servers", "{{server_host}}"]}
          }
        }
      ]
    },
    {
      "name": "Blocklist - Error Path",
      "item": [
        {
          "name": "GET /api/v1/blocklist/accounts - Unauthenticated (401)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 401', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/accounts", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "accounts"]}
          }
        },
        {
          "name": "POST /api/v1/blocklist/accounts - Missing body (400)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 400 or 422', () => pm.expect([400, 422]).to.include(pm.response.code));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{}"},
            "url": {"raw": "{{baseUrl}}/api/v1/blocklist/accounts", "host": ["{{baseUrl}}"], "path": ["api", "v1", "blocklist", "accounts"]}
          }
        },
        {
          "name": "GET /api/v1/blocklist/status - Status check (authenticated)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/blocklist/status?accountName={{account_name}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "blocklist", "status"],
              "query": [{"key": "accountName", "value": "{{account_name}}"}]
            }
          }
        }
      ]
    }
  ]
}
