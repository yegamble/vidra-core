                "exec": [
                  "// Backend should handle gracefully - either 400 or treat as 0",
                  "pm.test('Status is 200 or 400', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos?limit=10&offset=-1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos"],
              "query": [
                {"key": "limit", "value": "10"},
                {"key": "offset", "value": "-1"}
              ]
            }
          }
        },
        {
          "name": "List Videos - Page Size > 1000 (Edge)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Backend should cap at max limit (usually 100)",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Response capped at max limit', () => {",
                  "  if (json.data) {",
                  "    pm.expect(json.data.length).to.be.at.most(100);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
