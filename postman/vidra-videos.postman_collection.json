        {
          "name": "Update Video - Wrong Owner (403)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This test requires a video ID from a different user",
                  "// Set other_user_video_id in environment if available"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Expected 403 if other_user_video_id is set, otherwise skip",
                  "if (pm.environment.get('other_user_video_id')) {",
                  "  pm.test('Status is 403', () => pm.response.to.have.status(403));",
                  "} else {",
                  "  pm.test.skip('Skipped - requires other_user_video_id');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{other_user_video_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{other_user_video_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Attempting unauthorized update\"\n}"
            }
          }
        },
        {
          "name": "Delete Video - Wrong Owner (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('other_user_video_id')) {",
                  "  pm.test('Status is 403', () => pm.response.to.have.status(403));",
                  "} else {",
                  "  pm.test.skip('Skipped - requires other_user_video_id');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
