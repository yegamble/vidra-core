{
  "info": {
    "name": "Vidra Core Videos CRUD API",
    "_postman_id": "b7c7c7c0-1111-4000-9000-bbbbbbbbbbbb",
    "description": "Postman collection for Vidra Core video CRUD operations: list, search, create, get, update, delete with positive and negative tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://app-test:8080",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "video_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Videos - Happy Path",
      "item": [
        {
          "name": "Create Video",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const wrap = pm.response.json();",
                  "const json = wrap.data || {};",
                  "pm.test('Response has video ID', () => {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.collectionVariables.set('video_id', json.id);",
                  "  pm.environment.set('video_id', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Video {{$timestamp}}\",\n  \"description\": \"This is a test video for Postman collection\",\n  \"privacy\": \"public\",\n  \"tags\": [\"test\", \"automation\"],\n  \"language\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Get Video by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const wrap = pm.response.json();",
                  "const json = wrap.data || {};",
                  "pm.test('Response has video data', () => {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('title');",
                  "  pm.expect(json).to.have.property('privacy');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{video_id}}"]
            }
          }
        },
        {
          "name": "List Videos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Response has data array', () => {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});",
                  "pm.test('Response has pagination', () => {",
                  "  pm.expect(json).to.have.property('meta');",
                  "  pm.expect(json.meta).to.have.property('total');",
                  "  pm.expect(json.meta).to.have.property('offset');",
                  "  pm.expect(json.meta).to.have.property('limit');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos"],
              "query": [
                {"key": "limit", "value": "20"},
                {"key": "offset", "value": "0"}
              ]
            }
          }
        },
        {
          "name": "Search Videos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Response has data array', () => {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/search?q=test&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "search"],
              "query": [
                {"key": "q", "value": "test"},
                {"key": "limit", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Update Video",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const wrap = pm.response.json();",
                  "const json = wrap.data || {};",
                  "pm.test('Video updated', () => {",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json.title).to.include('Updated');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{video_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Test Video\",\n  \"description\": \"Updated description\",\n  \"privacy\": \"unlisted\"\n}"
            }
          }
        },
        {
          "name": "Get User Videos",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use the user_id from auth flow or default to video owner",
                  "if (!pm.collectionVariables.get('user_id')) {",
                  "  pm.collectionVariables.set('user_id', pm.environment.get('user_id') || 'me');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Response has data array', () => {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{user_id}}/videos?limit=10&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{user_id}}", "videos"],
              "query": [
                {"key": "limit", "value": "10"},
                {"key": "offset", "value": "0"}
              ]
            }
          }
        },
        {
          "name": "Delete Video",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204 or 200', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{video_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{video_id}}"]
            }
          }
        }
      ]
    },
