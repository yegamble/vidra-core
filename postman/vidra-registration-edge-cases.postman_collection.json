    {
      "name": "Setup: Generate Random Suffix",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate random suffix for unique test data",
              "const timestamp = Date.now();",
              "const random = Math.floor(Math.random() * 100000);",
              "pm.collectionVariables.set('random_suffix', `${timestamp}_${random}`);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Health check to verify API is running and generate test variables"
      },
      "response": []
    },
    {
      "name": "Baseline: Valid Registration",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = pm.collectionVariables.get('random_suffix');",
              "pm.collectionVariables.set('test_username_valid', `valid_${suffix}`.substring(0, 30));",
              "pm.collectionVariables.set('test_email', `valid_${suffix}@example.com`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201 or acceptable', function() {",
              "    pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  pm.test('Response has user data', function() {",
              "      const jsonData = pm.response.json();",
              "      pm.expect(jsonData.data).to.have.property('user');",
              "      pm.expect(jsonData.data.user).to.have.property('id');",
              "      pm.expect(jsonData.data.user).to.have.property('username');",
              "  });",
              "",
              "  pm.test('Response has access token', function() {",
              "      const jsonData = pm.response.json();",
              "      pm.expect(jsonData.data).to.have.property('access_token');",
              "      pm.expect(jsonData.data.access_token).to.be.a('string');",
              "  });",
              "",
              "  pm.test('Username matches request', function() {",
              "      const jsonData = pm.response.json();",
              "      const requestBody = JSON.parse(pm.request.body.raw);",
              "      pm.expect(jsonData.data.user.username).to.equal(requestBody.username);",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username_valid}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"SecurePass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Baseline test with valid credentials. Should succeed with 201 Created."
      },
      "response": []
