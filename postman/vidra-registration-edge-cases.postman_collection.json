            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 Bad Request or 409 Conflict', function() {",
              "    pm.expect([400, 409, 500]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Response contains error message', function() {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('error');",
              "});",
              "",
              "pm.test('Error indicates username issue', function() {",
              "    const jsonData = pm.response.json();",
              "    const errorMsg = JSON.stringify(jsonData).toLowerCase();",
              "    pm.expect(errorMsg).to.match(/username|too long|invalid|exceeds/);",
              "});",
              "",
              "// WARNING: If this test returns 201, there's a security vulnerability!",
              "if (pm.response.code === 201) {",
              "    console.error('❌ SECURITY VULNERABILITY: Username > 50 chars was accepted!');",
              "    console.error('Database truncation may cause collisions');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
