    {
      "name": "Edge Case: Username Exactly 50 Characters",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Create username exactly 50 chars",
              "const suffix = pm.collectionVariables.get('random_suffix');",
              "const base = 'user50_';",
              "const remaining = 50 - base.length - suffix.length;",
              "const padding = 'x'.repeat(Math.max(0, remaining));",
              "let username50 = (base + padding + suffix).substring(0, 50);",
              "",
              "pm.collectionVariables.set('test_username_50', username50);",
              "pm.collectionVariables.set('test_email', `${username50}@example.com`);",
              "",
              "console.log('Username length:', username50.length);",
              "console.log('Username:', username50);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201 or 400', function() {",
              "    pm.expect([201, 400, 409]).to.include(pm.response.code);",
              "});",
              "",
              "if (pm.response.code === 201) {",
              "  pm.test('Username is exactly 50 characters', function() {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.user.username.length).to.equal(50);",
              "  });",
              "",
              "  pm.test('Username stored correctly without truncation', function() {",
              "    const jsonData = pm.response.json();",
              "    const requestBody = JSON.parse(pm.request.body.raw);",
              "    pm.expect(jsonData.data.user.username).to.equal(requestBody.username);",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_username_50}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"SecurePass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        },
        "description": "Test boundary condition: username at maximum allowed length (50 chars)"
      },
      "response": []
    },
