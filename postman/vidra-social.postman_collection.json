        {
          "name": "Delete Comment",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status is 200, 204, or 404', () => pm.expect([200, 204, 404]).to.include(pm.response.code));"], "type": "text/javascript"}}],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/comments/{{comment_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "comments", "{{comment_id}}"]}
          }
        }
      ]
