          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/comments/{{comment_id}}/moderate", "host": ["{{baseUrl}}"], "path": ["api", "v1", "comments", "{{comment_id}}", "moderate"]},
            "body": {"mode": "raw", "raw": "{\"action\": \"hide\"}"}
          }
