          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/comments/{{comment_id}}/flag", "host": ["{{baseUrl}}"], "path": ["api", "v1", "comments", "{{comment_id}}", "flag"]}
          }
        },
