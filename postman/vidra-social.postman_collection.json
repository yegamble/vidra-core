{
  "info": {
    "name": "Vidra Core Social API (Comments & Channels)",
    "_postman_id": "c8d8d8d0-2222-4000-9000-cccccccccccc",
    "description": "Postman collection for Vidra Core comments and channels: CRUD operations, subscriptions, and moderation with positive and negative tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Sync environment variables into collection variables so {{var}} resolves correctly",
          "['video_id', 'access_token'].forEach(function(key) {",
          "  var envVal = pm.environment.get(key);",
          "  if (envVal) {",
          "    pm.collectionVariables.set(key, envVal);",
          "  }",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "video_id", "value": "", "type": "string"},
    {"key": "comment_id", "value": "", "type": "string"},
    {"key": "channel_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Comments - Happy Path",
      "item": [
        {
          "name": "List Video Comments",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status is 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));", "if (pm.response.code === 200) {", "  const json = pm.response.json();", "  pm.test('Response has data array', () => pm.expect(json).to.have.property('data'));", "}"], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/comments", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "comments"]}
          }
        },
        {
          "name": "Create Comment",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status is 201 or 400 or 404', () => pm.expect([201, 400, 404]).to.include(pm.response.code));", "if (pm.response.code === 201) {", "  const json = pm.response.json();", "  pm.test('Response has comment ID', () => {", "    const id = (json.data && json.data.id) ? json.data.id : json.id;", "    pm.expect(id).to.be.ok;", "    pm.collectionVariables.set('comment_id', id);", "  });", "}"], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/videos/{{video_id}}/comments", "host": ["{{baseUrl}}"], "path": ["api", "v1", "videos", "{{video_id}}", "comments"]},
            "body": {"mode": "raw", "raw": "{\"text\": \"This is a test comment from Postman\"}"}
          }
        },
        {
          "name": "Get Comment",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status is 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));"], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/comments/{{comment_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "comments", "{{comment_id}}"]}
