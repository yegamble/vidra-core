        {
          "name": "Delete Comment",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status is 200 or 204', () => pm.expect(pm.response.code).to.be.oneOf([200, 204]));"], "type": "text/javascript"}}],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/comments/{{comment_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "comments", "{{comment_id}}"]}
          }
