    {
      "name": "05 - Rate Limiting Tests",
      "item": [
        {
          "name": "Import Rate Limit - Burst Test",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Track request number",
                  "let requestNum = pm.environment.get('burst_request_num') || 0;",
                  "requestNum++;",
                  "pm.environment.set('burst_request_num', requestNum);",
                  "console.log('Burst request #' + requestNum);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const requestNum = pm.environment.get('burst_request_num');",
                  "",
                  "if (requestNum <= 10) {",
                  "    pm.test('First 10 requests should succeed or be rate limited', () => {",
                  "        pm.expect([201, 400, 403, 404, 429, 500]).to.include(pm.response.code);",
                  "    });",
                  "} else {",
                  "    pm.test('Subsequent requests should be rate limited', () => {",
                  "        pm.expect(pm.response.code).to.equal(429);",
                  "    });",
                  "}",
                  "",
                  "if (pm.response.code === 429) {",
                  "    pm.test('Rate limit error message provided', () => {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response).to.have.property('error');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_url\": \"https://sample-videos.com/video{{$randomInt}}/test.mp4\",\n  \"target_privacy\": \"private\"\n}"
