          }
        },
        {
          "name": "Create Comment - XSS Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('XSS payload should be sanitized or rejected', () => {",
                  "    if (pm.response.code === 201) {",
                  "        const response = pm.response.json();",
                  "        const commentBody = response.data.body || response.body;",
                  "        ",
                  "        pm.test('Script tags removed or escaped', () => {",
                  "            pm.expect(commentBody).to.not.include('<script>');",
                  "            pm.expect(commentBody).to.not.include('javascript:');",
                  "        });",
                  "    } else {",
                  "        pm.expect([400, 404, 422, 500]).to.include(pm.response.code);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"body\": \"<script>alert('XSS')</script>This is a comment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{test_video_id}}/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "videos",
                "{{test_video_id}}",
                "comments"
              ]
            }
          }
        },
        {
          "name": "Create Comment - SQL Injection Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SQL injection should not cause errors', () => {",
                  "    pm.expect([200, 201, 400, 403, 404, 422, 500]).to.include(pm.response.code);",
                  "    pm.expect(pm.response.code).to.not.equal(500);",
                  "});",
                  "",
                  "pm.test('No database error exposed', () => {",
                  "    const responseText = pm.response.text().toLowerCase();",
                  "    pm.expect(responseText).to.not.include('sql');",
                  "    pm.expect(responseText).to.not.include('database');",
                  "    pm.expect(responseText).to.not.include('postgres');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
