    {
      "name": "04 - Comment Edge Cases",
      "item": [
        {
          "name": "Get Comments - Non-existent Video",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Should handle non-existent video gracefully', () => {",
                  "    pm.expect([200, 400, 403, 404, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Returns empty comments array', () => {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.data || []).to.be.an('array').that.is.empty;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/00000000-0000-0000-0000-000000000000/comments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "videos",
                "00000000-0000-0000-0000-000000000000",
                "comments"
