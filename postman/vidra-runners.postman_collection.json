    {
      "name": "Job Lifecycle: Success Path",
      "item": [
        {
          "name": "Request Job (poll for work)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 200 = job available; 204 = no job available (both valid)",
                  "pm.test('Status is 200 or 204', () => {",
                  "  pm.expect([200, 204]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Job payload returned', () => {",
                  "    pm.expect(body.success).to.be.true;",
                  "    pm.expect(body.data).to.have.property('uuid');",
                  "  });",
                  "  pm.environment.set('runner_job_uuid', body.data.uuid);",
                  "  console.log('Job UUID:', body.data.uuid);",
                  "} else {",
                  "  console.log('No job available — skipping accept/update/success steps');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"runnerToken\": \"{{runner_token}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/runners/jobs/request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "runners", "jobs", "request"]
            }
          },
          "response": []
        },
