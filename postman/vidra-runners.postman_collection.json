{
  "info": {
    "name": "Vidra Core Remote Runners API",
    "description": "Test collection for the remote runner lifecycle: registration, job dispatch, progress updates, file upload, and admin management.\n\n## Lifecycle Covered\n\n1. **Admin Setup** - Create registration token\n2. **Runner Registration** - Runner registers with token, receives runner token\n3. **Job Request** - Runner polls for available encoding job\n4. **Job Accept** - Runner claims the job\n5. **Progress Updates** - Runner reports intermediate progress\n6. **Success/Error/Abort** - Runner reports terminal state\n7. **File Upload** - Runner posts encoded output files\n8. **Admin Cleanup** - Cancel, delete jobs, delete runner\n\n## Environment Variables Required\n\n- `baseUrl` - API base URL (e.g., http://localhost:8080)\n- `access_token` - Admin JWT access token\n\n## Variables Set During Run\n\n- `runner_registration_token` - Token used to register a runner\n- `runner_token` - Token returned after runner registration\n- `runner_id` - UUID of the registered runner\n- `runner_reg_token_id` - UUID of the registration token (for cleanup)\n- `runner_job_uuid` - UUID of the accepted job",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const adminToken = pm.environment.get('admin_access_token');",
          "if (adminToken) {",
          "  pm.collectionVariables.set('access_token', adminToken);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Admin: Registration Tokens",
      "item": [
        {
          "name": "List Registration Tokens (empty)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Response has data envelope', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.data).to.have.property('total');",
                  "  pm.expect(body.data).to.have.property('data');",
                  "  pm.expect(body.data.total).to.equal(0);",
                  "  pm.expect(body.data.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/runners/registration-tokens",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "runners", "registration-tokens"]
            }
          },
          "response": []
        },
        {
          "name": "Create Registration Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Token returned in data', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body.data).to.have.property('id');",
                  "  pm.expect(body.data).to.have.property('token');",
                  "  pm.expect(body.data.token).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.environment.set('runner_registration_token', body.data.token);",
                  "pm.environment.set('runner_reg_token_id', body.data.id);",
                  "console.log('Registration token:', body.data.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/runners/registration-tokens/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "runners", "registration-tokens", "generate"]
            }
          },
          "response": []
        },
        {
          "name": "Create Registration Token With Expiry",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const future = new Date(Date.now() + 7 * 24 * 3600 * 1000).toISOString();",
                  "pm.environment.set('token_expires_at', future);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => {",
                  "  pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Expiry present in response', () => {",
                  "  pm.expect(body.data).to.have.property('expiresAt');",
                  "});",
                  "// Clean up this extra token (save id for deletion)",
                  "pm.environment.set('extra_reg_token_id', body.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"expiresAt\": \"{{token_expires_at}}\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/runners/registration-tokens/generate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "runners", "registration-tokens", "generate"]
            }
          },
          "response": []
        },
