                  "  return;",
                  "}",
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Accept response has job', () => {",
                  "  pm.expect(body.success).to.be.true;",
                  "  pm.expect(body.data).to.have.property('job');",
