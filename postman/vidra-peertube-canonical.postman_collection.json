  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Verify authenticated user from auth collection",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const authSuiteToken = pm.environment.get('access_token');",
                  "if (authSuiteToken) {",
                  "  pm.test('Auth suite token exists', () => pm.expect(authSuiteToken).to.be.a('string').and.not.empty);",
                  "  pm.response.to.have.status(200);",
                  "} else {",
                  "  pm.test('Standalone canonical run can start without auth-suite token', () => pm.expect([200, 401]).to.include(pm.response.code));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const wrap = pm.response.json();",
                  "pm.expect(wrap).to.have.nested.property('data.access_token');",
                  "pm.environment.set('admin_access_token', wrap.data.access_token);",
                  "pm.environment.unset('canonical_channel_id');",
                  "pm.environment.unset('canonical_collaborator_id');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"admin@example.com\",\"password\":\"admin123\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Register collaborator invitee",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.environment.set('collaborator_username', `ptcollab${suffix}`);",
                  "pm.environment.set('collaborator_email', `ptcollab${suffix}@example.com`);",
                  "pm.environment.set('collaborator_password', 'Password123!');",
                  "pm.environment.unset('collaborator_access_token');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const wrap = pm.response.json();",
                  "pm.expect(wrap).to.have.nested.property('data.access_token');",
                  "pm.environment.set('collaborator_access_token', wrap.data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{collaborator_username}}\",\n  \"email\": \"{{collaborator_email}}\",\n  \"password\": \"{{collaborator_password}}\",\n  \"display_name\": \"PeerTube Collaborator\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        }
      ]
    },
