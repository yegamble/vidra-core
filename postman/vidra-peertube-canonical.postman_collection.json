    {
      "name": "PeerTube Handle and Collaborators",
      "item": [
        {
          "name": "POST /api/v1/channels - create channel for handle-based compatibility checks",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('canonical_channel_handle', `ptcanonical${Date.now()}`);"
