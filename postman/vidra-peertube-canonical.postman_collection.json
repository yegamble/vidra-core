              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const wrap = pm.response.json();",
                  "pm.environment.set('canonical_channel_id', wrap.data.id);",
                  "pm.expect(wrap.data.handle).to.eql(pm.environment.get('canonical_channel_handle'));"
