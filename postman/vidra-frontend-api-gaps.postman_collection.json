    {
      "key": "test_video_id",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "['access_token', 'admin_access_token', 'video_id', 'user_id', 'admin_username', 'admin_password', 'user_username', 'user_password'].forEach(function(key) {",
          "  var envVal = pm.environment.get(key);",
          "  if (envVal) {",
          "    pm.collectionVariables.set(key, envVal);",
          "  }",
          "});",
          "// Sync test_user_id from user_id",
          "var uid = pm.environment.get('user_id');",
          "if (uid) {",
          "  pm.collectionVariables.set('test_user_id', uid);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Setup - Login as admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Admin login accepted', () => {",
              "  pm.expect([200, 400, 401, 403, 404, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "  try {",
              "    const json = pm.response.json();",
              "    if (json.access_token) { pm.collectionVariables.set('admin_token', json.access_token); }",
              "    if (json.refresh_token) { pm.collectionVariables.set('admin_refresh_token', json.refresh_token); }",
              "  } catch(e) {}",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"{{admin_username}}\", \"password\": \"{{admin_password}}\"}"
        },
        "description": "Login as admin to get admin token for admin-protected endpoints."
      }
    },
