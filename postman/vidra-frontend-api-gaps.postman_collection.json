    "description": "E2E tests for new endpoints added to support the Iris frontend: public user profiles, admin user/video management, view history, and notification preferences.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://app-test:8080",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
