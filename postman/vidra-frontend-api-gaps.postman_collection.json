    {
      "name": "Public User Profile",
      "item": [
        {
          "name": "GET /api/v1/users/{id} - Happy path",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', () => {",
                  "  pm.expect([200, 400, 403, 404, 409, 422, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  try {",
                  "    const json = pm.response.json();",
                  "    pm.test('Response has success flag', () => pm.expect((json||{}).success).to.be.ok);",
                  "    pm.test('Response has data with user fields', () => {",
                  "      pm.expect((json.data||{})).to.have.property('id');",
                  "      pm.expect((json.data||{})).to.have.property('username');",
                  "      pm.expect((json.data||{})).to.not.have.property('password_hash');",
                  "      pm.expect((json.data||{})).to.not.have.property('two_factor_secret');",
                  "    });",
                  "  } catch(e) { /* response format mismatch */ }",
                  "  }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{test_user_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{test_user_id}}"
              ]
            },
            "description": "Get public user profile by ID. No auth required. Sensitive fields must be stripped."
          }
        },
        {
          "name": "GET /api/v1/users/{id} - 404 not found",
          "event": [
