{
  "info": {
    "name": "Vidra Core Channel Sync API",
    "description": "Test collection for channel synchronization: create, list, trigger, and delete syncs.\n\nPeerTube-compatible channel sync endpoints for external feed ingestion.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `access_token` - JWT access token\n- `channel_id` - UUID of an existing channel\n\n## Variables Set During Run\n- `channel_sync_id` - UUID of created sync",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Channel Sync",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Channel sync may not be implemented yet (404) or succeed (200/201)",
              "pm.test('Status is 200, 201, or 404 (not implemented)', () => {",
              "  pm.expect([200, 201, 404]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.test('Sync created', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    pm.expect(body.data).to.have.property('id');",
              "  });",
              "  pm.environment.set('channel_sync_id', body.data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel_id\": \"{{channel_id}}\",\n  \"external_channel_url\": \"https://www.youtube.com/feeds/videos.xml?channel_id=UC_x5XG1OV2P6uZZ5FSM9Ttw\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/video-channel-syncs",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "video-channel-syncs"]
        }
      },
      "response": []
    },
    {
      "name": "List Channel Syncs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200 or 404 (not implemented)', () => {",
              "  pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/video-channel-syncs",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "video-channel-syncs"]
        }
      },
      "response": []
    },
    {
      "name": "Trigger Sync Now",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 202, 204, or 404 (not implemented)', () => {",
              "  pm.expect([200, 202, 204, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/video-channel-syncs/{{channel_sync_id}}/sync",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "video-channel-syncs", "{{channel_sync_id}}", "sync"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Channel Sync",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 204, or 404 (not implemented)', () => {",
              "  pm.expect([200, 204, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/video-channel-syncs/{{channel_sync_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "video-channel-syncs", "{{channel_sync_id}}"]
        }
      },
      "response": []
    }
  ]
}
