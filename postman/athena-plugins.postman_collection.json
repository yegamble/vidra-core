              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"settings\": {\"updated_via_postman\": true}}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/plugins/{{plugin_npm_name}}/settings",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "plugins", "{{plugin_npm_name}}", "settings"]
            },
            "description": "Update plugin settings (PeerTube-compatible route)."
          },
          "response": []
        }
