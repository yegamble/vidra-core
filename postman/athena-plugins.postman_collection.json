        {
          "name": "Update Plugin Settings",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Settings update response', () => {",
                  "    pm.expect(body.success).to.be.true;",
                  "    pm.expect(body.data).to.have.property('npmName');",
