{
  "info": {
    "name": "Vidra Core E2E: Video Lifecycle",
    "description": "End-to-end video lifecycle: login, create channel, create video, check encoding, add captions, rate, comment, and verify.\n\nThis collection tests the complete video content creation workflow.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n\n## Variables Set During Run\n- `e2e_vid_access_token` - JWT access token\n- `e2e_vid_channel_id` - Created channel UUID\n- `e2e_vid_video_id` - Created video UUID\n- `e2e_vid_caption_id` - Created caption UUID\n- `e2e_vid_comment_id` - Created comment UUID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"}
  ],
  "item": [
    {
      "name": "Login as User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now();",
              "pm.environment.set('e2e_vid_username', 'e2evid_' + ts);",
              "pm.environment.set('e2e_vid_email', 'e2evid_' + ts + '@example.com');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or acceptable', () => {",
              "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.test('Registered with token', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    pm.expect(body.data).to.have.property('access_token');",
              "  });",
              "  pm.environment.set('e2e_vid_access_token', body.data.access_token);",
              "  pm.environment.set('e2e_vid_user_id', body.data.user.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{e2e_vid_username}}\",\n  \"email\": \"{{e2e_vid_email}}\",\n  \"password\": \"E2eVidPass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "Create Channel",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 201, or acceptable', () => {",
              "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.test('Channel created', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    pm.expect(body.data).to.have.property('id');",
              "  });",
              "  pm.environment.set('e2e_vid_channel_id', body.data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_vid_access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"handle\": \"e2evidchan{{$timestamp}}\",\n  \"displayName\": \"E2E Video Test Channel\",\n  \"description\": \"Channel for E2E video lifecycle testing\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/channels",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "channels"]
        }
      },
      "response": []
    },
    {
      "name": "Create Video",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 201, or acceptable', () => {",
              "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.test('Video created with ID', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    pm.expect(body.data).to.have.property('id');",
              "  });",
              "  pm.environment.set('e2e_vid_video_id', body.data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_vid_access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"E2E Test Video\",\n  \"channel_id\": \"{{e2e_vid_channel_id}}\",\n  \"description\": \"A test video for E2E lifecycle verification\",\n  \"privacy\": \"public\",\n  \"tags\": [\"test\", \"e2e\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos"]
        }
      },
      "response": []
    },
    {
      "name": "Get Video (verify created)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is acceptable', () => {",
              "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('Video data returned', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    pm.expect(body.data).to.have.property('id');",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{e2e_vid_video_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{e2e_vid_video_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Add Caption",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 201, 400, 403, 404, or 500', () => {",
              "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.test('Caption added', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    if (body.data && body.data.id) {",
              "      pm.environment.set('e2e_vid_caption_id', body.data.id);",
              "    }",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_vid_access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"language\": \"en\",\n  \"content\": \"1\\n00:00:01,000 --> 00:00:05,000\\nE2E test caption content.\",\n  \"format\": \"srt\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{e2e_vid_video_id}}/captions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{e2e_vid_video_id}}", "captions"]
        }
      },
      "response": []
    },
    {
      "name": "Rate Video (like)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 204, 400, 403, 404, or 500', () => {",
              "  pm.expect([200, 204, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_vid_access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": \"like\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{e2e_vid_video_id}}/rating",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{e2e_vid_video_id}}", "rating"]
        }
      },
      "response": []
    },
    {
      "name": "Add Comment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 201, 400, 403, 404, or 500', () => {",
              "  pm.expect([200, 201, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const body = pm.response.json();",
              "  pm.test('Comment created', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    if (body.data && body.data.id) {",
              "      pm.environment.set('e2e_vid_comment_id', body.data.id);",
              "    }",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_vid_access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Great E2E test video! This comment validates the full lifecycle.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{e2e_vid_video_id}}/comments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{e2e_vid_video_id}}", "comments"]
        }
      },
      "response": []
    },
    {
      "name": "Get Video (verify all fields)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is acceptable', () => {",
              "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('Video has expected structure', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "    pm.expect(body.data).to.have.property('id');",
              "    pm.expect(body.data).to.have.property('name');",
              "    pm.expect(body.data).to.have.property('description');",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{e2e_vid_access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/videos/{{e2e_vid_video_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "videos", "{{e2e_vid_video_id}}"]
        }
      },
      "response": []
    }
  ]
}
