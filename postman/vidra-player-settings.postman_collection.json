{
  "info": {
    "name": "Vidra Core Player Settings API",
    "description": "Test collection for video player settings: get/update instance and channel player configuration.\n\nPeerTube-compatible player settings endpoints.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `access_token` - JWT access token\n- `admin_access_token` - Admin JWT access token\n- `channel_id` - UUID of an existing channel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "['access_token', 'admin_access_token'].forEach(function(key) { var envVal = pm.environment.get(key); if (envVal) { pm.collectionVariables.set(key, envVal); } });"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://app-test:8080" },
    { "key": "access_token", "value": "" },
    { "key": "admin_access_token", "value": "" },
    { "key": "channel_id", "value": "" }
  ],
  "item": [
    {
      "name": "Get Video Player Settings (defaults)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => {",
              "  pm.expect(pm.response.code).to.equal(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Player settings returned', () => {",
              "  pm.expect(body).to.be.an('object');",
              "  pm.expect(body.instance || body.success).to.be.ok;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/config",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "config"]
        }
      },
      "response": []
    },
    {
      "name": "Update Custom Config (player section)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 403, or 404', () => {",
              "  pm.expect([200, 403, 404]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('Config updated', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"player\": {\n    \"autoplay\": false,\n    \"p2p_enabled\": true\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/config/custom",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "config", "custom"]
        }
      },
      "response": []
    },
    {
      "name": "Get Custom Config (verify player update)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200, 403, or 404', () => {",
              "  pm.expect([200, 403, 404]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.test('Config returned', () => {",
              "    pm.expect(body).to.have.property('success', true);",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/config/custom",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "config", "custom"]
        }
      },
      "response": []
    },
    {
      "name": "Error: Update Config Without Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 401 or 403', () => {",
              "  pm.expect([401, 403]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"player\": {\n    \"autoplay\": true\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/config/custom",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "config", "custom"]
        }
      },
      "response": []
    }
  ]
}
