{
  "info": {
    "name": "Vidra Core E2E: Bitcoin Payment Flow",
    "description": "End-to-end Bitcoin payment workflow via BTCPay Server: create invoice, check status, list invoices.\n\nThis collection tests the complete payment lifecycle.\n\n## Environment Variables Required\n- `baseUrl` - API base URL\n- `admin_username` - Admin username\n- `admin_password` - Admin password",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login succeeds', function() { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.collectionVariables.set('access_token', json.data.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"{{admin_username}}\",\"password\":\"{{admin_password}}\"}" },
        "url": { "raw": "{{baseUrl}}/api/v1/users/token", "host": ["{{baseUrl}}"], "path": ["api","v1","users","token"] }
      }
    },
    {
      "name": "Create Invoice (50k sats)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invoice created', function() { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.expect(json.data.status).to.equal('New');",
              "pm.collectionVariables.set('invoice_id', json.data.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\"amount_sats\":50000,\"currency\":\"BTC\"}" },
        "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices", "host": ["{{baseUrl}}"], "path": ["api","v1","payments","invoices"] }
      }
    },
    {
      "name": "Get Invoice",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invoice retrieved', function() { pm.response.to.have.status(200); });",
              "pm.test('Has required fields', function() {",
              "  var d = pm.response.json().data;",
              "  pm.expect(d).to.have.property('amount_sats');",
              "  pm.expect(d).to.have.property('checkout_link');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices/{{invoice_id}}", "host": ["{{baseUrl}}"], "path": ["api","v1","payments","invoices","{{invoice_id}}"] }
      }
    },
    {
      "name": "List Invoices",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('List succeeds', function() { pm.response.to.have.status(200); });",
              "pm.test('Returns array', function() { pm.expect(pm.response.json().data).to.be.an('array'); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
        "url": { "raw": "{{baseUrl}}/api/v1/payments/invoices?count=15", "host": ["{{baseUrl}}"], "path": ["api","v1","payments","invoices"], "query": [{"key":"count","value":"15"}] }
      }
    }
  ],
  "variable": [
    { "key": "access_token", "value": "" },
    { "key": "invoice_id", "value": "" }
  ]
}
