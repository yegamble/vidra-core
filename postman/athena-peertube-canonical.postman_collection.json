    {
      "name": "PeerTube Handle and Collaborators",
      "item": [
        {
          "name": "POST /api/v1/channels - create channel for handle-based compatibility checks",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('access_token')) {",
                  "  throw new Error('access_token missing. Run athena-auth before canonical compatibility tests.');",
                  "}",
                  "pm.collectionVariables.set('peertube_channel_handle', `ptcanonical${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('Created channel is wrapped', () => {",
                  "  pm.expect(json).to.have.nested.property('data.id');",
                  "});",
                  "pm.collectionVariables.set('peertube_channel_id', json.data.id);",
                  "pm.test('Created handle matches canonical test handle', () => {",
                  "  pm.expect(json.data.handle).to.equal(pm.collectionVariables.get('peertube_channel_handle'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"handle\": \"{{peertube_channel_handle}}\",\n  \"displayName\": \"PeerTube Canonical Test Channel\",\n  \"description\": \"Stateful compatibility channel for PeerTube-handle routes\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/channels",
              "host": [
