{
  "info": {
    "name": "Vidra Core Migration ETL",
    "description": "PeerTube instance migration endpoints for importing data from a remote PeerTube PostgreSQL database.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://app-test:8080",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "migrationId",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "var envToken = pm.environment.get('admin_access_token');",
          "if (envToken) {",
          "  pm.collectionVariables.set('adminToken', envToken);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{adminToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Admin Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var envToken = pm.environment.get('admin_access_token');",
              "if (envToken) {",
              "    pm.collectionVariables.set('adminToken', envToken);",
              "    pm.test('Admin token from environment', () => pm.expect(envToken).to.be.a('string'));",
              "} else if (pm.response.code === 200) {",
              "    const resp = pm.response.json();",
              "    var token = (resp.data && resp.data.access_token) || resp.access_token;",
              "    if (token) pm.collectionVariables.set('adminToken', token);",
              "    pm.test('Admin login successful', () => pm.response.to.have.status(200));",
              "} else {",
              "    pm.test('Admin login or token available', () => {",
              "        pm.expect([200, 401]).to.include(pm.response.code);",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Start PeerTube Migration",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Migration created or auth required', () => {",
              "    pm.expect([201, 401, 403]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 201) {",
              "    const resp = pm.response.json();",
              "    pm.expect(resp.success).to.be.true;",
              "    pm.expect(resp.data).to.have.property('id');",
              "    pm.collectionVariables.set('migrationId', resp.data.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_host\": \"peertube.example.com\",\n  \"source_db_host\": \"localhost\",\n  \"source_db_port\": 5432,\n  \"source_db_name\": \"peertube_prod\",\n  \"source_db_user\": \"peertube\",\n  \"source_db_password\": \"test_placeholder\",\n  \"source_media_path\": \"/var/www/peertube/storage\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/migrations/peertube",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "migrations", "peertube"]
        }
      }
    },
    {
      "name": "List Migrations",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Migrations listed or auth required', () => {",
              "    pm.expect([200, 401, 403]).to.include(pm.response.code);",
              "});",
              "if (pm.response.code === 200) {",
              "    const resp = pm.response.json();",
              "    pm.expect(resp.success).to.be.true;",
              "    pm.expect(resp.data).to.be.an('array');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/migrations?count=20&start=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "migrations"],
          "query": [
            { "key": "count", "value": "20" },
            { "key": "start", "value": "0" }
          ]
        }
      }
    },
    {
      "name": "Get Migration Status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Migration retrieved or not found', () => {",
              "    pm.expect([200, 401, 403, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/migrations/{{migrationId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "migrations", "{{migrationId}}"]
        }
      }
    },
    {
      "name": "Dry-Run Migration",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Dry-run created or not available', () => {",
              "    pm.expect([201, 400, 401, 403, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source_host\": \"peertube.example.com\",\n  \"source_db_host\": \"localhost\",\n  \"source_db_port\": 5432,\n  \"source_db_name\": \"peertube_prod\",\n  \"source_db_user\": \"peertube\",\n  \"source_db_password\": \"test_placeholder\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/migrations/{{migrationId}}/dry-run",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "migrations", "{{migrationId}}", "dry-run"]
        }
      }
    },
    {
      "name": "Cancel Migration",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Migration cancelled or not available', () => {",
              "    pm.expect([204, 400, 401, 403, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/migrations/{{migrationId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "migrations", "{{migrationId}}"]
        }
      }
    },
    {
      "name": "Get Migration Not Found",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 404 for unknown ID', () => {",
              "    pm.expect([401, 403, 404]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/migrations/00000000-0000-0000-0000-000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "admin", "migrations", "00000000-0000-0000-0000-000000000000"]
        }
      }
    }
  ]
}
