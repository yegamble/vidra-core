{
  "info": {
    "name": "Vidra Core Encoding Jobs API - Progress Tracking",
    "description": "Test collection for the new encoding job progress tracking endpoints.\n\n## Features\n- Real-time FFmpeg progress tracking (0-100%)\n- Authorization-based access control\n- Individual job status retrieval\n- Video-grouped job listing\n\n## Prerequisites\n- Valid JWT token with appropriate role (video owner, admin, or moderator)\n- Existing video with encoding jobs\n\n## Environment Variables Required\n- `baseUrl` - API base URL (e.g., http://localhost:8080)\n- `access_token` - JWT access token\n- `test_job_id` - An existing encoding job ID\n- `test_video_id` - An existing video ID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Individual Job Status",
      "item": [
        {
          "name": "Get Encoding Job - Owner Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Response has correct structure', () => {",
                  "  pm.expect(response).to.have.property('data');",
                  "  pm.expect(response.data).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Encoding job has all required fields', () => {",
                  "  const job = response.data;",
                  "  pm.expect(job).to.have.property('id');",
                  "  pm.expect(job).to.have.property('video_id');",
                  "  pm.expect(job).to.have.property('resolution');",
                  "  pm.expect(job).to.have.property('status');",
                  "  pm.expect(job).to.have.property('progress');",
                  "  pm.expect(job).to.have.property('created_at');",
                  "});",
                  "",
                  "pm.test('Progress is between 0 and 100', () => {",
                  "  const progress = response.data.progress;",
                  "  pm.expect(progress).to.be.at.least(0);",
                  "  pm.expect(progress).to.be.at.most(100);",
                  "});",
                  "",
                  "pm.test('Status is valid', () => {",
                  "  const validStatuses = ['pending', 'processing', 'completed', 'failed'];",
                  "  pm.expect(validStatuses).to.include(response.data.status);",
                  "});",
                  "",
                  "// Log progress",
                  "console.log(`Job ${response.data.id}: ${response.data.status} - ${response.data.progress}% complete`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/{{test_job_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "encoding", "jobs", "{{test_job_id}}"]
            },
            "description": "Get detailed status of a specific encoding job. Requires being the video owner, admin, or moderator."
          },
          "response": []
        },
        {
          "name": "Get Encoding Job - Unauthorized User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Use a different user's token or invalid token",
                  "pm.environment.set('unauthorized_token', 'invalid_or_different_user_token');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 or 403', () => {",
                  "  pm.expect([401, 403]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Error response has correct structure', () => {",
                  "  pm.expect(response).to.have.property('error');",
                  "  pm.expect(response.error).to.have.property('code');",
                  "  pm.expect(response.error).to.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{unauthorized_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/{{test_job_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "encoding", "jobs", "{{test_job_id}}"]
            },
            "description": "Verify unauthorized users cannot access encoding job details."
          },
          "response": []
        },
        {
          "name": "Get Encoding Job - Non-existent Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404 Not Found', () => {",
                  "  pm.expect(pm.response.code).to.equal(404);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Error indicates job not found', () => {",
                  "  pm.expect(response).to.have.property('error');",
                  "  pm.expect(response.error.code).to.match(/JOB_NOT_FOUND|NOT_FOUND/i);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/non-existent-job-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "encoding", "jobs", "non-existent-job-id"]
            },
            "description": "Test 404 response for non-existent encoding job."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Video Encoding Jobs",
      "item": [
        {
          "name": "Get Video Encoding Jobs - All Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Response has correct structure', () => {",
                  "  pm.expect(response).to.have.property('data');",
                  "  pm.expect(response.data).to.have.property('video_id');",
                  "  pm.expect(response.data).to.have.property('jobs');",
                  "  pm.expect(response.data).to.have.property('total');",
                  "  pm.expect(response.data).to.have.property('active_count');",
                  "  pm.expect(response.data).to.have.property('overall_progress');",
                  "});",
                  "",
                  "pm.test('Jobs array is valid', () => {",
                  "  pm.expect(response.data.jobs).to.be.an('array');",
                  "  if (response.data.jobs.length > 0) {",
                  "    const job = response.data.jobs[0];",
                  "    pm.expect(job).to.have.property('id');",
                  "    pm.expect(job).to.have.property('status');",
                  "    pm.expect(job).to.have.property('progress');",
                  "  }",
                  "});",
                  "",
                  "pm.test('Overall progress is calculated correctly', () => {",
                  "  const overallProgress = response.data.overall_progress;",
                  "  pm.expect(overallProgress).to.be.at.least(0);",
                  "  pm.expect(overallProgress).to.be.at.most(100);",
                  "});",
                  "",
                  "// Save data for other tests",
                  "if (response.data.jobs.length > 0) {",
                  "  pm.environment.set('sample_job_id', response.data.jobs[0].id);",
                  "}",
                  "",
                  "console.log(`Video ${response.data.video_id}: ${response.data.total} jobs, ${response.data.active_count} active`);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{test_video_id}}/encoding-jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{test_video_id}}", "encoding-jobs"]
            },
            "description": "Get all encoding jobs for a specific video."
          },
          "response": []
        },
        {
          "name": "Get Video Encoding Jobs - Active Only",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Only active jobs are returned', () => {",
                  "  const activeStatuses = ['pending', 'processing'];",
                  "  response.data.jobs.forEach(job => {",
                  "    pm.expect(activeStatuses).to.include(job.status);",
                  "  });",
                  "});",
                  "",
                  "pm.test('Active count matches job array length', () => {",
                  "  pm.expect(response.data.jobs.length).to.equal(response.data.active_count);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{test_video_id}}/encoding-jobs?active=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{test_video_id}}", "encoding-jobs"],
              "query": [
                {
                  "key": "active",
                  "value": "true",
                  "description": "Filter to show only active jobs"
                }
              ]
            },
            "description": "Get only active (pending/processing) encoding jobs for a video."
          },
          "response": []
        },
        {
          "name": "Get Video Encoding Jobs - Invalid Video ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => {",
                  "  pm.expect(pm.response.code).to.equal(400);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test('Error indicates invalid ID format', () => {",
                  "  pm.expect(response.error.message).to.match(/invalid.*video.*id/i);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/invalid-uuid-format/encoding-jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "invalid-uuid-format", "encoding-jobs"]
            },
            "description": "Test validation of video ID format."
          },
          "response": []
        },
        {
          "name": "Get Video Encoding Jobs - Admin Access",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Assume we have an admin token",
                  "// In real tests, you'd log in as admin first",
                  "pm.environment.set('admin_token', pm.environment.get('admin_access_token'));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin can access any video encoding jobs', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Response structure is valid', () => {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.data).to.have.property('jobs');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/videos/{{test_video_id}}/encoding-jobs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "videos", "{{test_video_id}}", "encoding-jobs"]
            },
            "description": "Verify admin users can access any video's encoding jobs."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Progress Monitoring Flow",
      "item": [
        {
          "name": "Monitor Job Progress",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// This would typically be in a loop or scheduled run",
                  "pm.variables.set('poll_count', parseInt(pm.variables.get('poll_count') || '0') + 1);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const job = response.data;",
                  "",
                  "pm.test('Job progress updates', () => {",
                  "  const lastProgress = parseInt(pm.variables.get('last_progress') || '0');",
                  "  pm.expect(job.progress).to.be.at.least(lastProgress);",
                  "  pm.variables.set('last_progress', job.progress);",
                  "});",
                  "",
                  "console.log(`Poll ${pm.variables.get('poll_count')}: ${job.status} - ${job.progress}%`);",
                  "",
                  "// Check if job is complete",
                  "if (job.status === 'completed' || job.status === 'failed') {",
                  "  pm.test('Job has finished', () => {",
                  "    if (job.status === 'completed') {",
                  "      pm.expect(job.progress).to.equal(100);",
                  "    }",
                  "    pm.expect(job).to.have.property('completed_at');",
                  "  });",
                  "  ",
                  "  // Stop polling in real scenario",
                  "  console.log(`Job finished with status: ${job.status}`);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/{{test_job_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "encoding", "jobs", "{{test_job_id}}"]
            },
            "description": "Poll for job progress updates. In a real monitoring scenario, this would be called periodically."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ]
}
