{
  "info": {
    "name": "Vidra Core Encoding Jobs API - Progress Tracking",
    "description": "Test collection for the new encoding job progress tracking endpoints.\n\n## Features\n- Real-time FFmpeg progress tracking (0-100%)\n- Authorization-based access control\n- Individual job status retrieval\n- Video-grouped job listing\n\n## Prerequisites\n- Valid JWT token with appropriate role (video owner, admin, or moderator)\n- Existing video with encoding jobs\n\n## Environment Variables Required\n- `baseUrl` - API base URL (e.g., http://app-test:8080)\n- `access_token` - JWT access token\n- `test_job_id` - An existing encoding job ID\n- `test_video_id` - An existing video ID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Sync environment variables into collection scope",
          "['access_token', 'video_id', 'admin_access_token'].forEach(function(key) {",
          "  var envVal = pm.environment.get(key);",
          "  if (envVal) { pm.collectionVariables.set(key, envVal); }",
          "});",
          "// Use video_id as test_video_id if not set",
          "var tvid = pm.environment.get('test_video_id') || pm.environment.get('video_id');",
          "if (tvid) { pm.collectionVariables.set('test_video_id', tvid); }",
          "var tjid = pm.environment.get('test_job_id');",
          "if (!tjid) {",
          "  pm.environment.set('test_job_id', '00000000-0000-0000-0000-000000000000');",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Individual Job Status",
      "item": [
        {
          "name": "Get Encoding Job - Owner Access",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Job may not exist in test environment",
                  "pm.test('Status is acceptable', () => {",
                  "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const response = pm.response.json();",
                  "  pm.test('Response has correct structure', () => {",
                  "    pm.expect(response).to.have.property('data');",
                  "  });",
                  "  }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/{{test_job_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "encoding",
                "jobs",
                "{{test_job_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Encoding Job - Unauthorized User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is acceptable error', () => {",
                  "  pm.expect([400, 401, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid_token",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/{{test_job_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "encoding",
                "jobs",
                "{{test_job_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Encoding Job - Non-existent Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is acceptable error', () => {",
                  "  pm.expect([400, 401, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/encoding/jobs/non-existent-job-id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "encoding",
                "jobs",
                "non-existent-job-id"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Video Encoding Jobs",
      "item": [
        {
          "name": "Get Video Encoding Jobs - All Jobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Video may not have encoding jobs in test env",
                  "pm.test('Status is acceptable', () => {",
                  "  pm.expect([200, 400, 403, 404, 405, 500]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
