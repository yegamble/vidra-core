{
  "info": {
    "name": "Vidra Core Playlists API",
    "_postman_id": "c3a3c3a3-0003-4000-9000-c3a3c3a3c3a3",
    "description": "Postman collection for playlist CRUD and video management within playlists.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "playlist_id", "value": "", "type": "string"},
    {"key": "video_id", "value": "", "type": "string"},
    {"key": "item_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Playlists - Happy Path",
      "item": [
        {
          "name": "POST /api/v1/playlists - Create playlist",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Has id', () => {",
            "  pm.expect(json).to.have.property('id');",
            "  pm.collectionVariables.set('playlist_id', json.id);",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"displayName\": \"My Test Playlist {{$timestamp}}\",\n  \"privacy\": \"public\",\n  \"description\": \"Test playlist for E2E\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/playlists", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists"]}
          }
        },
        {
          "name": "GET /api/v1/playlists - List playlists",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/playlists", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists"]}
          }
        },
        {
          "name": "GET /api/v1/playlists/:id - Get playlist",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('Has id', () => pm.expect(pm.response.json()).to.have.property('id'));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/playlists/{{playlist_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists", "{{playlist_id}}"]}
          }
        },
        {
          "name": "POST /api/v1/playlists/:id/items - Add video to playlist",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 201 or 200', () => pm.expect([200,201]).to.include(pm.response.code));",
            "const json = pm.response.json();",
            "if (json && json.id) pm.collectionVariables.set('item_id', json.id);"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"videoId\": \"{{video_id}}\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/playlists/{{playlist_id}}/items", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists", "{{playlist_id}}", "items"]}
          }
        },
        {
          "name": "GET /api/v1/playlists/:id/items - Get playlist items",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/playlists/{{playlist_id}}/items", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists", "{{playlist_id}}", "items"]}
          }
        },
        {
          "name": "PUT /api/v1/playlists/:id - Update playlist",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"displayName\": \"Updated Playlist Name\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/playlists/{{playlist_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists", "{{playlist_id}}"]}
          }
        },
        {
          "name": "DELETE /api/v1/playlists/:id - Delete playlist",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{baseUrl}}/api/v1/playlists/{{playlist_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists", "{{playlist_id}}"]}
          }
        }
      ]
    },
    {
      "name": "Playlists - Error Path",
      "item": [
        {
          "name": "GET /api/v1/playlists/nonexistent - Not found (404)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 404', () => pm.response.to.have.status(404));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/playlists/00000000-0000-0000-0000-000000000000", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists", "00000000-0000-0000-0000-000000000000"]}
          }
        },
        {
          "name": "POST /api/v1/playlists - Unauthenticated (401)",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 401', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"displayName\": \"Unauthorized Playlist\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/playlists", "host": ["{{baseUrl}}"], "path": ["api", "v1", "playlists"]}
          }
        }
      ]
    }
  ]
}
