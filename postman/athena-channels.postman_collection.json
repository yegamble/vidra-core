{
  "info": {
    "name": "Athena Channels API",
    "_postman_id": "c2a2c2a2-0002-4000-9000-c2a2c2a2c2a2",
    "description": "Postman collection for channel CRUD, subscription, avatar/banner management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://app-test:8080", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"},
    {"key": "channel_id", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Channels - Happy Path",
      "item": [
        {
          "name": "POST /api/v1/channels - Create channel",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.test('Has channel id', () => {",
            "  pm.expect(json).to.have.property('id');",
            "  pm.collectionVariables.set('channel_id', json.id);",
            "});"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"test-channel-{{$timestamp}}\",\n  \"displayName\": \"Test Channel\",\n  \"description\": \"A test channel for E2E tests\"\n}"},
            "url": {"raw": "{{baseUrl}}/api/v1/channels", "host": ["{{baseUrl}}"], "path": ["api", "v1", "channels"]}
          }
        },
        {
          "name": "GET /api/v1/channels - List channels",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Response is array or has data', () => pm.expect(json).to.satisfy(r => Array.isArray(r) || r.data !== undefined));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/channels", "host": ["{{baseUrl}}"], "path": ["api", "v1", "channels"]}
          }
        },
        {
          "name": "GET /api/v1/channels/:id - Get channel by ID",
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status is 200', () => pm.response.to.have.status(200));",
            "pm.test('Has id field', () => pm.expect(pm.response.json()).to.have.property('id'));"
          ], "type": "text/javascript"}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/channels/{{channel_id}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "channels", "{{channel_id}}"]}
          }
        },
        {
