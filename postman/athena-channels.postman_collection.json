          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{baseUrl}}/api/v1/channels/{{channel_id}}/videos", "host": ["{{baseUrl}}"], "path": ["api", "v1", "channels", "{{channel_id}}", "videos"]}
          }
        },
        {
          "name": "GET /api/v1/users/me/channels - My channels",
