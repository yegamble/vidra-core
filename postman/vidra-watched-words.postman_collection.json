        {
          "name": "Get Auto-Tag Policies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Policies returned', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auto-tags/policies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auto-tags", "policies"]
            }
          },
          "response": []
        },
        {
          "name": "Update Auto-Tag Policies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Policies updated', () => {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_access_token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"review\": [\"watched-words\"],\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auto-tags/policies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auto-tags", "policies"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
