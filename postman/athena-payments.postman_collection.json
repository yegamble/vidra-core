        {
          "name": "Create Payment Intent - With Video ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const videoId = pm.environment.get('test_video_id') || pm.environment.get('video_id') || '00000000-0000-0000-0000-000000000001';",
                  "pm.collectionVariables.set('payment_video_id', videoId);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 404', () => {",
                  "  pm.expect([201, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Video-linked intent returned', () => {",
                  "    pm.expect(body.data).to.have.property('id');",
                  "    pm.expect(body.data.amount_iota).to.equal(500);",
                  "  });",
                  "} else {",
                  "  const body = pm.response.json();",
                  "  pm.test('VIDEO_NOT_FOUND error code', () => {",
                  "    pm.expect(body.success).to.be.false;",
                  "    pm.expect(body.error.code).to.equal('VIDEO_NOT_FOUND');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
