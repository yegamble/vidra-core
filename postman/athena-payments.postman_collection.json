                  "    pm.expect(body.data).to.have.property('amount_iota');",
                  "    pm.expect(body.data).to.have.property('status');",
                  "  });",
                  "  pm.environment.set('payment_intent_id', body.data.id);",
                  "  console.log('Payment intent ID:', body.data.id);",
