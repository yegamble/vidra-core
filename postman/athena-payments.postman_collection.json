{
  "info": {
    "name": "Athena IOTA Payments API",
    "description": "Test collection for the IOTA crypto payments lifecycle: wallet creation, payment intents, and transaction history.\n\n## Lifecycle Covered\n\n1. **Create Wallet** \u2014 generate an IOTA wallet for the authenticated user\n2. **Get Wallet** \u2014 retrieve wallet balance and address\n3. **Create Payment Intent** \u2014 initiate a payment for a video or general tip\n4. **Get Payment Intent** \u2014 check intent status\n5. **Transaction History** \u2014 list past transactions with pagination\n6. **Error cases** \u2014 auth failures, duplicate wallet, invalid amounts\n\n## Environment Variables Required\n\n- `baseUrl` - API base URL\n- `access_token` - JWT access token\n\n## Variables Set During Run\n\n- `payment_intent_id` - ID of the created payment intent",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Create Wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 201 = created, 409 = wallet already exists (both valid)",
                  "pm.test('Status is 201 or 409', () => {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Wallet fields returned', () => {",
                  "    pm.expect(body.success).to.be.true;",
                  "    pm.expect(body.data).to.have.property('address');",
                    "    pm.expect(body.data).to.have.property('balance_iota');",
                  "    pm.expect(body.data).to.have.property('user_id');",
                  "  });",
                  "  // Save wallet address for subsequent requests",
                  "  if (body.data && body.data.address) {",
                  "    pm.environment.set('wallet_address', body.data.address);",
                  "  }",
                  "  console.log('Wallet address:', body.data.address);",
                  "} else {",
                  "  console.log('Wallet already exists for user (409)');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/wallet",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "wallet"
              ]
            },
            "description": "Create an IOTA wallet for the authenticated user. Returns 409 if wallet already exists."
          },
          "response": []
        },
        {
          "name": "Get Wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// After Create Wallet succeeds, Get Wallet must return 200",
                  "// 404 only if wallet creation failed (409 from earlier step)",
                  "pm.test('Status is 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Wallet data structure', () => {",
                  "    pm.expect(body.success).to.be.true;",
                  "    pm.expect(body.data).to.have.property('address');",
                    "    pm.expect(body.data).to.have.property('balance_iota');",
                    "    pm.expect(body.data.balance_iota).to.be.a('number').and.at.least(0);",
                  "  });",
                  "  console.log('Wallet balance:', body.data.balance_iota, 'IOTA');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/wallet",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "wallet"
              ]
            }
          },
          "response": []
        },
